@model List<DotNetLearning.Models.Chapter>
@{
    ViewData["Title"] = ".NET 學習平台";

    // ── 核心路線（有順序的三大主軸）──
    var corePath = new[]
    {
        new { Key = "csharp",   Name = "C# 基礎",          Icon = "🔷", Color = "#9B59B6", Desc = "語言根基：變數、OOP、LINQ、非同步" },
        new { Key = "aspnet",   Name = "ASP.NET Core MVC",  Icon = "🌐", Color = "#3498DB", Desc = "Web 開發：路由、Controller、DI、API" },
        new { Key = "database", Name = "資料庫 & ORM",      Icon = "🗄️", Color = "#E74C3C", Desc = "資料層：SQL、EF Core、Dapper、優化" },
    };

    // ── 進階擴充（獨立模組）──
    var advancedModules = new Dictionary<string, (string Name, string Icon, string Color, string Desc)>
    {
        ["frontend"]       = ("前端基礎",          "🎨", "#E91E63", "HTML / CSS / JavaScript 與前後端整合"),
        ["git"]            = ("Git 版本控制",      "📝", "#F57C00", "版本管理、分支、GitHub 協作"),
        ["server"]         = ("架 Server 概念",    "🖥️", "#00897B", "Nginx、反向代理、負載平衡、監控"),
        ["patterns"]       = ("設計模式 & SOLID",  "🏛️", "#E67E22", "架構思維：SOLID、GoF、Clean Architecture"),
        ["infrastructure"] = ("快取 & 日誌 & 效能","⚡", "#9B59B6", "系統調校：Caching、Serilog、Profiling"),
        ["network"]        = ("網路 TCP/IP",       "🌍", "#27AE60", "通訊基礎：OSI、HTTP、DNS、WebSocket"),
        ["security"]       = ("資安",              "🔒", "#F39C12", "安全開發：JWT、加密、OWASP Top 10"),
        ["docker"]         = ("Docker & 部署",     "🐳", "#1ABC9C", "容器化：Docker、CI/CD、雲端部署"),
        ["ai"]             = ("AI 應用",           "🤖", "#FF6B6B", "AI 輔助：Prompt、MCP、Claude Code"),
        ["aimodel"]        = ("AI 模型與語言",     "🧠", "#7C4DFF", "LLM、RAG、Embedding、IPAS 知識"),
        ["claudecode"]     = ("Claude Code 工具",  "🔌", "#00BCD4", "不用 CMD 做專案、No-Code 流程"),
        ["project"]        = ("專案實戰",          "🛒", "#4CAF50", "電商、部落格、API 微服務完整開發"),
        ["iot"]            = ("IoT & POS 系統",    "🍓", "#FF5722", "Raspberry Pi、POS 開發、硬體整合"),
        ["vue"]            = ("Vue.js",             "💚", "#42B883", "漸進式框架：Composition API、Router、Pinia"),
        ["react"]          = ("React",              "⚛️", "#61DAFB", "元件化 UI：Hooks、JSX、Redux、Next.js"),
        ["angular"]        = ("Angular",            "🅰️", "#DD0031", "企業級框架：TypeScript、RxJS、DI、Forms"),
    };
}

<div class="home-layout">

    <!-- ══════════ 公告欄 ══════════ -->
    @{
        var announcements = ViewBag.Announcements as List<DotNetLearning.Models.Announcement> ?? new();
        var typeMap = new Dictionary<string,string> { {"success","#22c55e"}, {"warning","#f59e0b"}, {"danger","#ef4444"}, {"info","#3b82f6"} };
        var iconMap = new Dictionary<string,string> { {"success","✅"}, {"warning","⚠️"}, {"danger","🚨"}, {"info","📢"} };
    }
    @if (announcements.Any())
    {
    <div id="announcementBar" style="background:#0d1117;border-bottom:1px solid #30363d;padding:0;">
        <div style="max-width:1200px;margin:0 auto;padding:0 20px;">
            @foreach (var ann in announcements)
            {
                var color = typeMap.GetValueOrDefault(ann.Type, "#3b82f6");
                var icon = iconMap.GetValueOrDefault(ann.Type, "📢");
                <div class="ann-item" style="display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid #21262d;position:relative;" data-ann-id="@ann.Id">
                    <span style="font-size:1.1rem;flex-shrink:0;margin-top:1px;">@icon</span>
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                            @if (ann.IsPinned) { <span style="background:rgba(239,68,68,0.15);color:#ef4444;border:1px solid rgba(239,68,68,0.3);border-radius:4px;padding:1px 7px;font-size:0.72rem;font-weight:700;">📌 置頂</span> }
                            <span style="font-weight:700;color:@color;font-size:0.95rem;">@ann.Title</span>
                            <span style="color:#8b949e;font-size:0.78rem;">@ann.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                        </div>
                        <div style="color:#c9d1d9;font-size:0.875rem;margin-top:4px;line-height:1.5;">@ann.Content</div>
                    </div>
                    <button onclick="dismissAnn(this,@ann.Id)" style="flex-shrink:0;background:none;border:none;color:#8b949e;cursor:pointer;font-size:1rem;padding:4px;line-height:1;" title="本次關閉（不影響公告內容）">✕</button>
                </div>
            }
        </div>
    </div>
    <script>
    function dismissAnn(btn, id) {
        btn.closest('.ann-item').style.display = 'none';
        var dismissed = JSON.parse(sessionStorage.getItem('dismissedAnns') || '[]');
        dismissed.push(id);
        sessionStorage.setItem('dismissedAnns', JSON.stringify(dismissed));
        // Hide entire bar if all dismissed
        var bar = document.getElementById('announcementBar');
        if (!bar.querySelector('.ann-item[style*="display"]:not([style*="none"])') && !bar.querySelector('.ann-item:not([style*="display: none"])')) {
            bar.style.display = 'none';
        }
    }
    // Hide already-dismissed on load (session only — refresh brings them back)
    (function(){
        var dismissed = JSON.parse(sessionStorage.getItem('dismissedAnns') || '[]');
        var allHidden = true;
        document.querySelectorAll('.ann-item').forEach(function(el) {
            if (dismissed.includes(parseInt(el.dataset.annId))) {
                el.style.display = 'none';
            } else { allHidden = false; }
        });
        if (allHidden && document.getElementById('announcementBar')) document.getElementById('announcementBar').style.display = 'none';
    })();
    </script>
    }

