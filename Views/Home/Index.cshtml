    <!-- ══════════ 核心學習路線 ══════════ -->
    <section class="section-block" id="core-path">
        <div class="section-header">
            <h2 class="section-title" data-i18n="section-core">核心學習路線</h2>
            <p class="section-subtitle" data-i18n="section-core-desc">按順序學習這三個主題，打好 .NET 開發基礎</p>
        </div>

        <!-- 視覺化路徑 -->
        <div class="learning-path">
            @for (int i = 0; i < corePath.Count; i++)
            {
                var cp = corePath[i];
                var chapters = Model.Where(c => c.Category == cp.Key).OrderBy(c => c.Order).ToList();
                <div class="path-node" style="--node-color: @cp.Color">
                    <div class="path-step-num">STEP @(i + 1)</div>
                    <div class="path-icon">@cp.Icon</div>
                    <h3 data-i18n="@("path-" + cp.Key + "-name")">@cp.Name</h3>
                    <p class="path-desc" data-i18n="@("path-" + cp.Key + "-desc")">@cp.Desc</p>
                    <div class="path-meta">@chapters.Count <span data-i18n="home-chapters-unit">個章節</span></div>
                    <a href="/Home/Chapter/@(chapters.FirstOrDefault()?.Slug ?? "#")" class="path-start-btn" data-i18n="home-start-btn">開始 →</a>
                </div>
                @if (i < corePath.Count - 1)
                {
                    <div class="path-arrow">
                        <svg width="40" height="24" viewBox="0 0 40 24"><path d="M0 12h32M26 4l8 8-8 8" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                }
            }
        </div>

        <!-- 核心路線展開卡片 -->
        <div class="core-cards">
            @for (int i = 0; i < corePath.Count; i++)
            {
                var cp = corePath[i];
                var chapters = Model.Where(c => c.Category == cp.Key).OrderBy(c => c.Order).ToList();
                if (!chapters.Any()) { continue; }
                <div class="category-card" style="--cat-color: @cp.Color">
                    <div class="category-header">
                        <div class="cat-icon-wrap">@cp.Icon</div>
                        <div>
                            <h2 data-i18n="@("path-" + cp.Key + "-name")">@cp.Name</h2>
                            <small>@chapters.Count <span data-i18n="home-chapters-unit">個章節</span> · STEP @(i + 1)</small>
                        </div>
                        <a href="/Note/DownloadAll/@cp.Key" class="dl-all-btn">📥 <span data-i18n="home-note-btn">筆記</span></a>
                    </div>
                    <ul class="chapter-list">
                        @foreach (var ch in chapters)
                        {
                            string label = ch.Level switch { "beginner" => "初學", "intermediate" => "中級", "advanced" => "進階", _ => "" };
                            string cls   = ch.Level switch { "beginner" => "badge-green", "intermediate" => "badge-blue", "advanced" => "badge-red", _ => "" };
                            string i18nLevel = "ch-level-" + ch.Level;
                            <li>
                                <a href="/Home/Chapter/@ch.Slug" class="chapter-link">
                                    <span class="ch-icon">@ch.Icon</span>
                                    <span class="ch-title" data-i18n="@("ch-" + ch.Slug)">@TitleFor(ch)</span>
                                    <span class="badge @cls" data-i18n="@i18nLevel">@label</span>
                                    <span class="ch-arrow">›</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </section>

