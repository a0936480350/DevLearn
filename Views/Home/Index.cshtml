@model List<DotNetLearning.Models.Chapter>
@using DotNetLearning.Models
@{
    ViewData["Title"] = ".NET 學習平台";
    var currentLang = ViewBag.CurrentLang as string ?? "zh";

    // 依目前語言挑章節標題（未翻 → fallback 繁中）
    string TitleFor(DotNetLearning.Models.Chapter ch) => currentLang switch
    {
        "ja" when !string.IsNullOrWhiteSpace(ch.TitleJa) => ch.TitleJa!,
        "en" when !string.IsNullOrWhiteSpace(ch.TitleEn) => ch.TitleEn!,
        _ => ch.Title,
    };

    // 分類資料從 Models/CategoryInfo.cs 的 CategoryRegistry 拿，新增分類只改那一處
    // DB 冒出未註冊的 category 會自動 append（safety net）
    var dbCats = Model.Select(c => c.Category).Distinct().ToList();
    var allCatsOrdered = CategoryRegistry.OrderedForRender(dbCats);
    var corePath = allCatsOrdered.Where(c => c.IsCore).ToList();
    var advancedModules = allCatsOrdered.Where(c => !c.IsCore).ToList();
}

<div class="home-layout">

    <!-- ══════════ 公告欄 ══════════ -->
    @{
        var announcements = ViewBag.Announcements as List<DotNetLearning.Models.Announcement> ?? new();
        var typeMap = new Dictionary<string,string> { {"success","#22c55e"}, {"warning","#f59e0b"}, {"danger","#ef4444"}, {"info","#3b82f6"} };
        var iconMap = new Dictionary<string,string> { {"success","✅"}, {"warning","⚠️"}, {"danger","🚨"}, {"info","📢"} };
    }
    @if (announcements.Any())
    {
    <div id="announcementBar" style="background:#0d1117;border-bottom:1px solid #30363d;padding:0;">
        <div style="max-width:1200px;margin:0 auto;padding:0 20px;">
            @foreach (var ann in announcements)
            {
                var color = typeMap.GetValueOrDefault(ann.Type, "#3b82f6");
                var icon = iconMap.GetValueOrDefault(ann.Type, "📢");
                <div class="ann-item" style="display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #21262d;position:relative;" data-ann-id="@ann.Id">
                    <span style="font-size:1rem;flex-shrink:0;margin-top:2px;">@icon</span>
                    <div style="flex:1;min-width:0;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        @if (ann.IsPinned) { <span style="background:rgba(239,68,68,0.15);color:#ef4444;border:1px solid rgba(239,68,68,0.3);border-radius:4px;padding:1px 6px;font-size:0.7rem;font-weight:700;">📌</span> }
                        <a href="/Announcement#ann-@ann.Id" style="font-weight:700;color:@color;font-size:0.9rem;text-decoration:none;">@ann.Title</a>
                        <span style="color:#8b949e;font-size:0.75rem;">@ann.CreatedAt.ToString("MM/dd")</span>
                        <span style="color:#58a6ff;font-size:0.78rem;margin-left:auto;white-space:nowrap;"><a href="/Announcement#ann-@ann.Id" style="color:#58a6ff;text-decoration:none;">閱讀更多 →</a></span>
                    </div>
                    <button onclick="dismissAnn(this,@ann.Id)" style="flex-shrink:0;background:none;border:none;color:#8b949e;cursor:pointer;font-size:0.9rem;padding:4px;line-height:1;" title="關閉">✕</button>
                </div>
            }
        </div>
    </div>
    <script>
    function dismissAnn(btn, id) {
        btn.closest('.ann-item').style.display = 'none';
        var dismissed = JSON.parse(sessionStorage.getItem('dismissedAnns') || '[]');
        dismissed.push(id);
        sessionStorage.setItem('dismissedAnns', JSON.stringify(dismissed));
        // Hide entire bar if all dismissed
        var bar = document.getElementById('announcementBar');
        if (!bar.querySelector('.ann-item[style*="display"]:not([style*="none"])') && !bar.querySelector('.ann-item:not([style*="display: none"])')) {
            bar.style.display = 'none';
        }
    }
    // Hide already-dismissed on load (session only — refresh brings them back)
    (function(){
        var dismissed = JSON.parse(sessionStorage.getItem('dismissedAnns') || '[]');
        var allHidden = true;
        document.querySelectorAll('.ann-item').forEach(function(el) {
            if (dismissed.includes(parseInt(el.dataset.annId))) {
                el.style.display = 'none';
            } else { allHidden = false; }
        });
        if (allHidden && document.getElementById('announcementBar')) document.getElementById('announcementBar').style.display = 'none';
    })();
    </script>
    }

    <!-- ══════════ 新手任務 ══════════ -->
    <style>
    #newbieTaskCard{max-width:720px;margin:16px auto;padding:0;border-radius:12px;background:#161b22;border:1px solid #30363d;overflow:hidden}
    .task-progress-bar{height:3px;background:#21262d;margin:0}
    .task-progress-bar .bar{height:100%;background:#22c55e;transition:width .5s ease}
    .task-header{display:flex;align-items:center;padding:12px 16px 8px;gap:10px}
    .task-header>span:first-child{font-size:14px;font-weight:700;color:#e6edf3}
    .task-header .task-progress{font-size:12px;color:#8b949e;margin-left:auto}
    .task-header .task-dismiss{background:none;border:none;color:#8b949e;cursor:pointer;font-size:16px;padding:2px 6px;line-height:1}
    .task-list{display:flex;flex-direction:column;gap:1px;padding:4px 16px 10px}
    .task-item{display:flex;align-items:center;gap:10px;padding:6px 8px;border-radius:6px}
    .task-item .task-check{font-size:15px;flex-shrink:0;width:20px;text-align:center}
    .task-item .task-label{flex:1;font-size:13px;color:#c9d1d9}
    .task-item.done .task-label{text-decoration:line-through;color:#6b7280}
    .task-item .task-go{font-size:12px;color:#58a6ff;text-decoration:none;font-weight:600}
    .task-item.done .task-go{display:none}
    .task-reward{padding:8px 16px 14px;font-size:12px;color:#f59e0b;display:flex;align-items:center;gap:6px}
    .task-celebration{display:none;text-align:center;padding:20px;font-size:15px;color:#22c55e;font-weight:700}
    .task-celebration.show{display:block}
    </style>
    <div id="newbieTaskCard" style="display:none;">
        <div class="task-progress-bar"><div class="bar" id="taskBar" style="width:0%"></div></div>
        <div class="task-header">
            <span>新手任務</span>
            <span class="task-progress" id="taskProgressText">0 / 6 完成</span>
            <button class="task-dismiss" onclick="dismissTasks()" title="關閉">&#x2715;</button>
        </div>
        <div class="task-list" id="taskList">
            <div class="task-item" data-task="register">
                <span class="task-check">&#x2610;</span>
                <span class="task-label">註冊帳號</span>
                <a href="/Account/Register" class="task-go">前往 &rarr;</a>
            </div>
            <div class="task-item" data-task="profile">
                <span class="task-check">&#x2610;</span>
                <span class="task-label">設定你的暱稱</span>
                <a href="/Account/Profile" class="task-go">前往 &rarr;</a>
            </div>
            <div class="task-item" data-task="chapter">
                <span class="task-check">&#x2610;</span>
                <span class="task-label">閱讀第一篇章節</span>
                <a href="/Home/Chapter/csharp-intro" class="task-go">前往 &rarr;</a>
            </div>
            <div class="task-item" data-task="quiz">
                <span class="task-check">&#x2610;</span>
                <span class="task-label">完成一次隨機測驗</span>
                <a href="/Quiz/Random" class="task-go">前往 &rarr;</a>
            </div>
            <div class="task-item" data-task="game">
                <span class="task-check">&#x2610;</span>
                <span class="task-label">玩一場遊戲</span>
                <a href="/CodeTutor" class="task-go">前往 &rarr;</a>
            </div>
            <div class="task-item" data-task="line">
                <span class="task-check">&#x2610;</span>
                <span class="task-label">加入 LINE 討論群組（限量送星巴克禮券！）</span>
                <a href="/Promotion/JoinLine" target="_blank" class="task-go">加入 &rarr;</a>
            </div>
        </div>
        <div class="task-reward" id="taskReward">&#x26A0;&#xFE0F; 完成所有任務並加入 LINE 群組，限量贈送 LINE 星巴克禮券（名額有限，送完為止）</div>
        <div class="task-celebration" id="taskCelebration">&#x1F389; 恭喜完成所有新手任務！</div>
    </div>
    <script>
    (function(){
        var STORAGE_KEY='newbieTasks', DISMISS_KEY='newbieTasksDismissed';
        var TOTAL=6;
        var defaults={register:false,profile:false,chapter:false,quiz:false,game:false,line:false};
        function load(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY))||Object.assign({},defaults);}catch(e){return Object.assign({},defaults);}}
        function save(t){localStorage.setItem(STORAGE_KEY,JSON.stringify(t));}
        function countDone(t){return Object.values(t).filter(Boolean).length;}

        // Auto-detect completed tasks
        function detect(tasks){
            var path=location.pathname.toLowerCase();
            if(path.indexOf('/home/chapter/')===0) tasks.chapter=true;
            if(path.indexOf('/quiz')===0) tasks.quiz=true;
            if(path==='/codetutor'||path==='/detective'||path==='/speed'||path==='/puzzle'||path==='/arena'||path==='/battle'||path==='/monopoly'||path==='/sqlgame') tasks.game=true;
            if(path==='/checkin') tasks.game=true;
            return tasks;
        }

        function render(tasks){
            var card=document.getElementById('newbieTaskCard');
            if(localStorage.getItem(DISMISS_KEY)){card.style.display='none';return;}
            var done=countDone(tasks);
            if(done>=TOTAL){
                document.getElementById('taskCelebration').classList.add('show');
                document.getElementById('taskReward').style.display='none';
                document.getElementById('taskList').style.display='none';
                document.getElementById('taskBar').style.width='100%';
                document.getElementById('taskProgressText').textContent=TOTAL+' / '+TOTAL+' 完成';
                card.style.display='block';
                setTimeout(function(){card.style.display='none';localStorage.setItem(DISMISS_KEY,'true');},4000);
                return;
            }
            document.getElementById('taskBar').style.width=(done/TOTAL*100)+'%';
            document.getElementById('taskProgressText').textContent=done+' / '+TOTAL+' 完成';
            document.querySelectorAll('.task-item').forEach(function(el){
                var key=el.dataset.task;
                if(tasks[key]){
                    el.classList.add('done');
                    el.querySelector('.task-check').textContent='\u2611';
                    el.querySelector('.task-check').style.color='#22c55e';
                }else{
                    el.classList.remove('done');
                    el.querySelector('.task-check').textContent='\u2610';
                    el.querySelector('.task-check').style.color='';
                }
            });
            card.style.display='block';
        }

        var tasks=load();
        tasks=detect(tasks);

        // Try to check profile via API
        fetch('/Account/Me').then(function(r){return r.ok?r.json():null;}).then(function(data){
            if(data && data.isRegistered) tasks.register=true;
            if(data && data.nickname && data.nickname.trim()!=='' && data.nickname!=='匿名學習者') tasks.profile=true;
            save(tasks);render(tasks);
        }).catch(function(){save(tasks);render(tasks);});

        window.dismissTasks=function(){
            localStorage.setItem(DISMISS_KEY,'true');
            document.getElementById('newbieTaskCard').style.display='none';
        };
    })();
    </script>

