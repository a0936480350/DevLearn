            </div>
            <div class="px-footer-copy">&copy; 2025 DevLearn. All rights reserved.</div>
        </div>
    </footer>

</div>

<!-- 隨機挑戰 Quiz Modal -->
<div id="quiz-modal" class="quiz-modal" style="display:none;">
    <div class="quiz-modal-inner">
        <button class="quiz-close" onclick="closeQuizModal()">✕</button>
        <div id="quiz-content"></div>
    </div>
</div>

@section Scripts {
<script>
function startRandomQuiz(count) {
    fetch('/Quiz/Random?count=' + count)
        .then(r => r.json())
        .then(data => {
            if (!data.questions || data.questions.length === 0) {
                alert('目前沒有測驗題目');
                return;
            }
            renderQuizModal(data.questions, count);
        })
        .catch(e => alert('載入失敗：' + e.message));
}

function renderQuizModal(questions, total) {
    const modal = document.getElementById('quiz-modal');
    const content = document.getElementById('quiz-content');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    let html = '<h2 class="quiz-title">⚡ 隨機挑戰 (' + questions.length + ' 題)</h2>';
    html += '<form id="random-quiz-form">';
    questions.forEach((q, i) => {
        html += '<div class="quiz-q">';
        html += '<div class="quiz-q-num">Q' + (i+1) + '</div>';
        html += '<div class="quiz-q-text">' + q.questionText + '</div>';
        if (q.type === 'fillin') {
            html += '<input type="text" name="q_' + q.id + '" class="quiz-input" placeholder="輸入答案..." />';
        } else if (q.options && q.options.length > 0) {
            q.options.forEach((opt, j) => {
                html += '<label class="quiz-option">';
                html += '<input type="radio" name="q_' + q.id + '" value="' + opt.replace(/"/g,'&quot;') + '" />';
                html += '<span>' + opt + '</span>';
                html += '</label>';
            });
        }
        html += '</div>';
    });
    html += '<button type="button" class="quiz-submit-btn" onclick="submitRandomQuiz()">提交答案</button>';
    html += '</form>';
    content.innerHTML = html;
    window._quizQuestions = questions;
}

function submitRandomQuiz() {
    const form = document.getElementById('random-quiz-form');
    const answers = {};
    window._quizQuestions.forEach(q => {
        const input = form.querySelector('[name="q_' + q.id + '"]');
        if (q.type === 'fillin') {
            answers[q.id] = input ? input.value : '';
        } else {
            const checked = form.querySelector('[name="q_' + q.id + '"]:checked');
            answers[q.id] = checked ? checked.value : '';
        }
    });

    fetch('/Quiz/SubmitRandom', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: answers })
    })
    .then(r => r.json())
    .then(result => renderQuizResult(result))
    .catch(e => alert('提交失敗：' + e.message));
}

function renderQuizResult(result) {
    const content = document.getElementById('quiz-content');
    const pct = Math.round((result.score / result.total) * 100);
    const grade = pct >= 80 ? '🏆 優秀' : pct >= 60 ? '👍 及格' : '💪 加油';

    let html = '<div class="quiz-result">';
    html += '<div class="result-circle" style="--pct:' + pct + '%"><span>' + result.score + '/' + result.total + '</span></div>';
    html += '<div class="result-grade">' + grade + ' (' + pct + '%)</div>';
    html += '</div>';

    result.details.forEach((d, i) => {
        const icon = d.isCorrect ? '✅' : '❌';
        html += '<div class="quiz-detail ' + (d.isCorrect ? 'correct' : 'wrong') + '">';
        html += '<div class="qd-head">' + icon + ' Q' + (i+1) + ': ' + d.questionText + '</div>';
        if (!d.isCorrect) {
            html += '<div class="qd-ans">你的答案：<code>' + (d.yourAnswer || '未作答') + '</code></div>';
            html += '<div class="qd-correct">正確答案：<code>' + d.correctAnswer + '</code></div>';
        }
        html += '<div class="qd-explain">💡 ' + d.explanation + '</div>';
        html += '</div>';
    });

    html += '<button class="quiz-submit-btn" onclick="closeQuizModal()">關閉</button>';
    content.innerHTML = html;
}

function closeQuizModal() {
    document.getElementById('quiz-modal').style.display = 'none';
    document.body.style.overflow = '';
}

// 用 ideas.js 的統一功能載入知識牆
loadIdeaWall();

// 載入老師免費分享
(function() {
    fetch('/Teacher/LatestPosts')
        .then(r => r.json())
        .then(posts => {
            var grid = document.getElementById('teacherPostsGrid');
            if (!posts || posts.length === 0) {
                grid.innerHTML = '<div style="color:var(--text-muted);font-size:13px;">目前還沒有老師分享內容</div>';
                return;
            }
            var html = '';
            posts.forEach(function(p) {
                var typeName = p.type === 'video' ? '&#x1F3AC; 影片' : p.type === 'resource' ? '&#x1F4E6; 資源' : '&#x1F4DD; 文章';
                html += '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:20px;transition:border-color 0.2s;cursor:pointer;" onclick="window.location.href=\'/Teacher/Detail/' + p.teacherId + '\'">';
                html += '  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">';
                html += '    <span style="font-size:11px;padding:2px 10px;border-radius:10px;background:rgba(99,102,241,0.1);color:var(--accent);">' + typeName + '</span>';
                html += '    <span style="font-size:11px;color:var(--text-muted);">' + p.createdAt + '</span>';
                html += '  </div>';
                html += '  <div style="font-size:15px;font-weight:700;margin-bottom:8px;">' + p.title + '</div>';
                html += '  <div style="font-size:13px;color:var(--text-muted);line-height:1.5;margin-bottom:12px;">' + p.preview + '</div>';
                html += '  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--text-muted);">';
                html += '    <span>&#x1F468;&#x200D;&#x1F3EB; ' + p.teacherName + '</span>';
                html += '    <span>&#x2764;&#xFE0F; ' + p.likes + ' 讚</span>';
                html += '  </div>';
                html += '  <div style="margin-top:10px;text-align:right;"><span style="font-size:13px;color:var(--accent);">閱讀更多 &rarr;</span></div>';
                html += '</div>';
            });
            grid.innerHTML = html;
        })
        .catch(function() {
            document.getElementById('teacherPostsGrid').innerHTML = '<div style="color:var(--text-muted);font-size:13px;">載入失敗</div>';
        });
})();
</script>

<script>
(function(){
    var canvas = document.getElementById('heroParticles');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var particles = [];
    var mouseX = 0, mouseY = 0;

    function resize() {
        canvas.width = canvas.parentElement.offsetWidth;
        canvas.height = canvas.parentElement.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // Create particles
    for (var i = 0; i < 60; i++) {
        particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            size: Math.random() * 3 + 1,
            opacity: Math.random() * 0.5 + 0.1,
            color: Math.random() > 0.5 ? '0,184,148' : '99,102,241'
        });
    }

    canvas.parentElement.addEventListener('mousemove', function(e) {
        var rect = canvas.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
    });

    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        particles.forEach(function(p, i) {
            // Move
            p.x += p.vx;
            p.y += p.vy;

            // Wrap around
            if (p.x < 0) p.x = canvas.width;
            if (p.x > canvas.width) p.x = 0;
            if (p.y < 0) p.y = canvas.height;
            if (p.y > canvas.height) p.y = 0;

            // Draw particle
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.color + ',' + p.opacity + ')';
            ctx.fill();

            // Draw connections between nearby particles
            particles.forEach(function(p2, j) {
                if (i >= j) return;
                var dx = p.x - p2.x;
                var dy = p.y - p2.y;
                var dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 120) {
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(p2.x, p2.y);
                    ctx.strokeStyle = 'rgba(0,184,148,' + (0.15 * (1 - dist / 120)) + ')';
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            });

            // Mouse interaction - particles move away
            var mdx = p.x - mouseX;
            var mdy = p.y - mouseY;
            var mDist = Math.sqrt(mdx * mdx + mdy * mdy);
            if (mDist < 100) {
                p.vx += mdx * 0.001;
                p.vy += mdy * 0.001;
            }

            // Damping
            p.vx *= 0.99;
            p.vy *= 0.99;
        });

        requestAnimationFrame(animate);
    }
    animate();
})();
</script>

<script>
// Typewriter effect for hero
(function(){
    var el = document.querySelector('.hero-content h1');
    if (!el) return;
    var original = el.innerHTML;
    el.innerHTML = '';
    el.style.visibility = 'visible';
    var i = 0;
    function type() {
        if (i < original.length) {
            // Handle HTML tags
            if (original[i] === '<') {
                var end = original.indexOf('>', i);
                el.innerHTML += original.substring(i, end + 1);
                i = end + 1;
            } else {
                el.innerHTML += original[i];
                i++;
            }
            setTimeout(type, 30);
        }
    }
    setTimeout(type, 500);
})();
</script>

<script>
// Counter animation
document.querySelectorAll('.stat-num').forEach(function(el) {
    var target = parseInt(el.textContent);
    if (isNaN(target)) return; // Skip "Free" etc
    var current = 0;
    var step = Math.ceil(target / 40);
    el.textContent = '0';
    var interval = setInterval(function() {
        current += step;
        if (current >= target) {
            current = target;
            clearInterval(interval);
        }
        el.textContent = current;
    }, 30);
});
</script>
}
