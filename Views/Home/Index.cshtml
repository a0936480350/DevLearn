        <!-- ─── 📎 檔案分享（PDF / PPT / Word / 圖片）─── -->
        <div style="margin-top:48px;padding-top:32px;border-top:1px dashed #30363d;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;flex-wrap:wrap;gap:10px;">
                <div>
                    <h3 style="font-size:1.1rem;font-weight:700;color:#e6edf3;margin:0;">📎 共享檔案</h3>
                    <p style="color:#8b949e;font-size:.85rem;margin:4px 0 0;">上傳 PDF / PPT / Word / 圖片 讓大家下載或預覽</p>
                </div>
                <a href="/SharedFile/Upload" class="btn-cta-primary" style="font-size:.85rem;padding:8px 18px;">📤 上傳檔案</a>
            </div>
            <div id="sharedFileList" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px;">
                <div style="color:#6e7681;font-size:.85rem;">載入中...</div>
            </div>
        </div>
    </section>

    <script>
        // 載入共享檔案列表
        (async () => {
            try {
                const r = await fetch('/SharedFile/List');
                if (!r.ok) return;
                const files = await r.json();
                const box = document.getElementById('sharedFileList');
                if (!files.length) {
                    box.innerHTML = '<div style="color:#6e7681;font-size:.85rem;grid-column:1/-1;text-align:center;padding:20px;">還沒有人上傳檔案，第一個就是你！</div>';
                    return;
                }
                box.innerHTML = files.map(f => {
                    const ext = (f.fileName.split('.').pop() || '').toLowerCase();
                    const icon = ext === 'pdf' ? '📕' : ['doc','docx'].includes(ext) ? '📘' : ['ppt','pptx'].includes(ext) ? '🎨' : ['xls','xlsx'].includes(ext) ? '📊' : ['png','jpg','jpeg','gif','webp'].includes(ext) ? '🖼️' : '📎';
                    const canPreview = ['pdf','png','jpg','jpeg','gif','webp','txt','md'].includes(ext);
                    const size = f.fileSize < 1024*1024 ? (f.fileSize/1024).toFixed(1)+' KB' : (f.fileSize/1024/1024).toFixed(1)+' MB';
                    return `
                        <div style="background:#161b22;border:1px solid #30363d;border-radius:10px;padding:14px;transition:all .2s;">
                            <div style="display:flex;gap:10px;align-items:flex-start;margin-bottom:10px;">
                                <div style="font-size:30px;line-height:1;">${icon}</div>
                                <div style="flex:1;min-width:0;">
                                    <div style="color:#e6edf3;font-weight:600;font-size:.9rem;line-height:1.3;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${f.title}">${f.title}</div>
                                    <div style="color:#6e7681;font-size:.72rem;">👤 ${f.uploadedBy} · 📏 ${size} · ⬇️ ${f.downloadCount}</div>
                                </div>
                            </div>
                            ${f.description ? `<div style="color:#8b949e;font-size:.78rem;line-height:1.4;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${f.description}</div>` : ''}
                            <div style="display:flex;gap:6px;">
                                ${canPreview ? `<a href="/SharedFile/Preview/${f.id}" target="_blank" style="flex:1;text-align:center;background:#1a3a5c;color:#58a6ff;padding:6px;border-radius:5px;text-decoration:none;font-size:.78rem;font-weight:600;">👁️ 預覽</a>` : ''}
                                <a href="/SharedFile/Download/${f.id}" style="flex:1;text-align:center;background:#1a4a2e;color:#3fb950;padding:6px;border-radius:5px;text-decoration:none;font-size:.78rem;font-weight:600;">⬇️ 下載</a>
                            </div>
                        </div>
                    `;
                }).join('');
            } catch (e) { console.error(e); }
        })();
    </script>

