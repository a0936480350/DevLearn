        <div class="section-header">
            <h2 class="section-title">核心學習路線</h2>
            <p class="section-subtitle">按順序學習這三個主題，打好 .NET 開發基礎</p>
        </div>

        <!-- 視覺化路徑 -->
        <div class="learning-path">
            @for (int i = 0; i < corePath.Length; i++)
            {
                var cp = corePath[i];
                var chapters = Model.Where(c => c.Category == cp.Key).OrderBy(c => c.Order).ToList();
                <div class="path-node" style="--node-color: @cp.Color">
                    <div class="path-step-num">STEP @(i + 1)</div>
                    <div class="path-icon">@cp.Icon</div>
                    <h3>@cp.Name</h3>
                    <p class="path-desc">@cp.Desc</p>
                    <div class="path-meta">@chapters.Count 個章節</div>
                    <a href="/Home/Chapter/@(chapters.FirstOrDefault()?.Slug ?? "#")" class="path-start-btn">開始 →</a>
                </div>
                @if (i < corePath.Length - 1)
                {
                    <div class="path-arrow">
                        <svg width="40" height="24" viewBox="0 0 40 24"><path d="M0 12h32M26 4l8 8-8 8" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                }
            }
        </div>

        <!-- 核心路線展開卡片 -->
        <div class="core-cards">
            @for (int i = 0; i < corePath.Length; i++)
            {
                var cp = corePath[i];
                var chapters = Model.Where(c => c.Category == cp.Key).OrderBy(c => c.Order).ToList();
                if (!chapters.Any()) { continue; }
                <div class="category-card" style="--cat-color: @cp.Color">
                    <div class="category-header">
                        <div class="cat-icon-wrap">@cp.Icon</div>
                        <div>
                            <h2>@cp.Name</h2>
                            <small>@chapters.Count 個章節 · STEP @(i + 1)</small>
                        </div>
                        <a href="/Note/DownloadAll/@cp.Key" class="dl-all-btn">📥 筆記</a>
                    </div>
                    <ul class="chapter-list">
                        @foreach (var ch in chapters)
                        {
                            string label = ch.Level switch { "beginner" => "初學", "intermediate" => "中級", "advanced" => "進階", _ => "" };
                            string cls   = ch.Level switch { "beginner" => "badge-green", "intermediate" => "badge-blue", "advanced" => "badge-red", _ => "" };
                            <li>
                                <a href="/Home/Chapter/@ch.Slug" class="chapter-link">
                                    <span class="ch-icon">@ch.Icon</span>
                                    <span class="ch-title">@ch.Title</span>
                                    <span class="badge @cls">@label</span>
                                    <span class="ch-arrow">›</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </section>

    <!-- ══════════ 進階擴充模組 ══════════ -->
    <section class="section-block" id="advanced-modules">
        <div class="section-header">
            <h2 class="section-title">進階擴充模組</h2>
            <p class="section-subtitle">核心路線學完後，依需求選擇深入的方向</p>
        </div>

        <div class="courses-container">
            @foreach (var mod in advancedModules)
            {
                var chapters = Model.Where(c => c.Category == mod.Key).OrderBy(c => c.Order).ToList();
                if (!chapters.Any()) { continue; }
                <div class="category-card" style="--cat-color: @mod.Value.Color">
                    <div class="category-header">
                        <div class="cat-icon-wrap">@mod.Value.Icon</div>
                        <div>
                            <h2>@mod.Value.Name</h2>
                            <small>@chapters.Count 個章節</small>
                        </div>
                        <a href="/Note/DownloadAll/@mod.Key" class="dl-all-btn">📥 筆記</a>
                    </div>
                    <ul class="chapter-list">
                        @foreach (var ch in chapters)
                        {
                            string label = ch.Level switch { "beginner" => "初學", "intermediate" => "中級", "advanced" => "進階", _ => "" };
                            string cls   = ch.Level switch { "beginner" => "badge-green", "intermediate" => "badge-blue", "advanced" => "badge-red", _ => "" };
                            <li>
                                <a href="/Home/Chapter/@ch.Slug" class="chapter-link">
                                    <span class="ch-icon">@ch.Icon</span>
                                    <span class="ch-title">@ch.Title</span>
                                    <span class="badge @cls">@label</span>
                                    <span class="ch-arrow">›</span>
