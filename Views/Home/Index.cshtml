                <img src="/images/code-screen.jpg" alt="程式碼學習" style="width:100%;height:280px;object-fit:cover;" />
            </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;">
            <div style="border-radius:16px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,0.4);">
                <img src="/images/tech-bg.jpg" alt="互動學習" style="width:100%;height:280px;object-fit:cover;" />
            </div>
            <div>
                <h2 style="font-size:1.8rem;font-weight:800;margin-bottom:16px;color:var(--text);" data-i18n="promo-game-title">邊玩邊學，不再枯燥</h2>
                <p style="color:var(--text-muted);line-height:1.8;margin-bottom:20px;" data-i18n="promo-game-desc">
                    速度挑戰、程式碼偵探、填字遊戲、每日一題...
                    用遊戲化方式學程式，積分排行榜讓你越學越上癮。
                </p>
                <a href="/Speed" style="color:var(--accent);font-weight:600;text-decoration:none;" data-i18n="promo-game-link">開始挑戰 →</a>
            </div>
        </div>
    </section>

    <!-- ══════════ 核心學習路線 ══════════ -->
    <section class="section-block" id="core-path">
        <div class="section-header">
            <h2 class="section-title" data-i18n="section-core">核心學習路線</h2>
            <p class="section-subtitle" data-i18n="section-core-desc">按順序學習這三個主題，打好 .NET 開發基礎</p>
        </div>

        <!-- 視覺化路徑 -->
        <div class="learning-path">
            @for (int i = 0; i < corePath.Length; i++)
            {
                var cp = corePath[i];
                var chapters = Model.Where(c => c.Category == cp.Key).OrderBy(c => c.Order).ToList();
                <div class="path-node" style="--node-color: @cp.Color">
                    <div class="path-step-num">STEP @(i + 1)</div>
                    <div class="path-icon">@cp.Icon</div>
                    <h3 data-i18n="@("path-" + cp.Key + "-name")">@cp.Name</h3>
                    <p class="path-desc" data-i18n="@("path-" + cp.Key + "-desc")">@cp.Desc</p>
                    <div class="path-meta">@chapters.Count <span data-i18n="home-chapters-unit">個章節</span></div>
                    <a href="/Home/Chapter/@(chapters.FirstOrDefault()?.Slug ?? "#")" class="path-start-btn" data-i18n="home-start-btn">開始 →</a>
                </div>
                @if (i < corePath.Length - 1)
                {
                    <div class="path-arrow">
                        <svg width="40" height="24" viewBox="0 0 40 24"><path d="M0 12h32M26 4l8 8-8 8" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                }
            }
        </div>

        <!-- 核心路線展開卡片 -->
        <div class="core-cards">
            @for (int i = 0; i < corePath.Length; i++)
            {
                var cp = corePath[i];
                var chapters = Model.Where(c => c.Category == cp.Key).OrderBy(c => c.Order).ToList();
                if (!chapters.Any()) { continue; }
                <div class="category-card" style="--cat-color: @cp.Color">
                    <div class="category-header">
                        <div class="cat-icon-wrap">@cp.Icon</div>
                        <div>
                            <h2 data-i18n="@("path-" + cp.Key + "-name")">@cp.Name</h2>
                            <small>@chapters.Count <span data-i18n="home-chapters-unit">個章節</span> · STEP @(i + 1)</small>
                        </div>
                        <a href="/Note/DownloadAll/@cp.Key" class="dl-all-btn">📥 <span data-i18n="home-note-btn">筆記</span></a>
                    </div>
                    <ul class="chapter-list">
                        @foreach (var ch in chapters)
                        {
                            string label = ch.Level switch { "beginner" => "初學", "intermediate" => "中級", "advanced" => "進階", _ => "" };
                            string cls   = ch.Level switch { "beginner" => "badge-green", "intermediate" => "badge-blue", "advanced" => "badge-red", _ => "" };
                            string i18nLevel = "ch-level-" + ch.Level;
                            <li>
                                <a href="/Home/Chapter/@ch.Slug" class="chapter-link">
                                    <span class="ch-icon">@ch.Icon</span>
                                    <span class="ch-title" data-i18n="@("ch-" + ch.Slug)">@ch.Title</span>
                                    <span class="badge @cls" data-i18n="@i18nLevel">@label</span>
                                    <span class="ch-arrow">›</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </section>

    <!-- ══════════ 進階擴充模組 ══════════ -->
    <section class="section-block" id="advanced-modules">
        <div class="section-header">
            <h2 class="section-title" data-i18n="section-advanced">進階擴充模組</h2>
            <p class="section-subtitle" data-i18n="section-advanced-desc">核心路線學完後，依需求選擇深入的方向</p>
        </div>

        <div class="courses-container">
            @foreach (var mod in advancedModules)
            {
                var chapters = Model.Where(c => c.Category == mod.Key).OrderBy(c => c.Order).ToList();
                if (!chapters.Any()) { continue; }
                <div class="category-card" style="--cat-color: @mod.Value.Color">
                    <div class="category-header">
                        <div class="cat-icon-wrap">@mod.Value.Icon</div>
                        <div>
                            <h2 data-i18n="@("path-" + mod.Key + "-name")">@mod.Value.Name</h2>
                            <small>@chapters.Count <span data-i18n="home-chapters-unit">個章節</span></small>
                        </div>
                        <a href="/Note/DownloadAll/@mod.Key" class="dl-all-btn">📥 <span data-i18n="home-note-btn">筆記</span></a>
                    </div>
                    <ul class="chapter-list">
                        @foreach (var ch in chapters)
                        {
                            string label = ch.Level switch { "beginner" => "初學", "intermediate" => "中級", "advanced" => "進階", _ => "" };
                            string cls   = ch.Level switch { "beginner" => "badge-green", "intermediate" => "badge-blue", "advanced" => "badge-red", _ => "" };
                            string i18nLevel = "ch-level-" + ch.Level;
                            <li>
                                <a href="/Home/Chapter/@ch.Slug" class="chapter-link">
                                    <span class="ch-icon">@ch.Icon</span>
                                    <span class="ch-title" data-i18n="@("ch-" + ch.Slug)">@ch.Title</span>
                                    <span class="badge @cls" data-i18n="@i18nLevel">@label</span>
                                    <span class="ch-arrow">›</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </section>

    <!-- ══════════ 隨機挑戰 ══════════ -->
    <section class="section-block" id="quick-challenge">
        <div class="section-header">
            <h2 class="section-title" data-i18n="section-challenge">隨機挑戰</h2>
            <p class="section-subtitle" data-i18n="section-challenge-desc">不用看課程也能測實力！隨機抽題，看看你的程度</p>
        </div>
        <div class="challenge-box">
            <div class="challenge-options">
                <button class="challenge-btn" onclick="startRandomQuiz(5)">
                    <span class="cb-num">5</span>
                    <span class="cb-label"><span data-i18n="challenge-quick">快速挑戰</span><br><small data-i18n="challenge-quick-time">3 分鐘</small></span>
                </button>
                <button class="challenge-btn" onclick="startRandomQuiz(10)">
                    <span class="cb-num">10</span>
                    <span class="cb-label"><span data-i18n="challenge-standard">標準測驗</span><br><small data-i18n="challenge-standard-time">8 分鐘</small></span>
                </button>
                <button class="challenge-btn" onclick="startRandomQuiz(20)">
                    <span class="cb-num">20</span>
                    <span class="cb-label"><span data-i18n="challenge-full">完整挑戰</span><br><small data-i18n="challenge-full-time">15 分鐘</small></span>
                </button>
            </div>
        </div>
    </section>

    <!-- ══════════ 知識分享牆 ══════════ -->
    <section class="section-block" id="idea-wall">
        <div class="section-header">
            <h2 class="section-title" data-i18n="section-ideas">知識分享牆</h2>
            <p class="section-subtitle" data-i18n="section-ideas-desc">看看大家的學習心得、筆記和想法</p>
        </div>
        <div class="idea-wall-actions">
            <button class="btn-cta-primary" onclick="postGlobalIdea()" style="font-size:.88rem;padding:10px 22px;" data-i18n="section-ideas-btn">分享你的想法</button>
        </div>
        <div id="globalIdeaWall" class="idea-wall-grid">
            <div class="idea-loading" data-i18n="home-idea-loading">載入中...</div>
        </div>
    </section>

    <!-- ══════════ 老師免費分享 ══════════ -->
    <section class="section-block" id="teacher-posts">
        <div class="section-header">
            <h2 class="section-title" data-i18n="section-teacher-posts">老師免費分享</h2>
            <p class="section-subtitle" data-i18n="section-teacher-posts-desc">來自平台老師的最新免費文章、影片和資源</p>
        </div>
        <div id="teacherPostsGrid" class="idea-wall-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;">
            <div style="color:var(--text-muted);font-size:13px;" data-i18n="home-teachers-loading">載入中...</div>
        </div>
    </section>

    <!-- ══════════ Footer ══════════ -->
    <footer class="px-footer">
        <div class="px-footer-inner">
            <div class="px-footer-brand">
                <div>
                    <div class="px-footer-title" data-i18n="footer-title">DevLearn · .NET 學習平台</div>
                    <div class="px-footer-sub">.NET Developer Learning Platform</div>
                </div>
            </div>
            <div class="px-footer-links">
                <a href="/" data-i18n="footer-home">首頁</a>
                <a href="/Leaderboard" data-i18n="footer-leaderboard">排行榜</a>
                <a href="/Scores" data-i18n="footer-scores">成績</a>
            </div>
            <div class="px-footer-copy">&copy; 2025 DevLearn. All rights reserved.</div>
        </div>
    </footer>

</div>

<!-- 隨機挑戰 Quiz Modal -->
<div id="quiz-modal" class="quiz-modal" style="display:none;">
    <div class="quiz-modal-inner">
        <button class="quiz-close" onclick="closeQuizModal()">✕</button>
        <div id="quiz-content"></div>
    </div>
</div>

@section Scripts {
<script>
function startRandomQuiz(count) {
    fetch('/Quiz/Random?count=' + count)
        .then(r => r.json())
        .then(data => {
            if (!data.questions || data.questions.length === 0) {
                alert(__t('quiz-load-failed'));
                return;
            }
            renderQuizModal(data.questions, count);
        })
        .catch(e => alert(__t('quiz-load-failed')));
}

function renderQuizModal(questions, total) {
    const modal = document.getElementById('quiz-modal');
    const content = document.getElementById('quiz-content');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    let html = '<h2 class="quiz-title">' + __t('quiz-title') + ' (' + questions.length + ' 題)</h2>';
    html += '<form id="random-quiz-form">';
    questions.forEach((q, i) => {
        html += '<div class="quiz-q">';
        html += '<div class="quiz-q-num">Q' + (i+1) + '</div>';
        html += '<div class="quiz-q-text">' + q.questionText + '</div>';
        if (q.type === 'fillin') {
            html += '<input type="text" name="q_' + q.id + '" class="quiz-input" placeholder="' + __t('quiz-fillin-ph') + '" />';
        } else if (q.options && q.options.length > 0) {
            q.options.forEach((opt, j) => {
                html += '<label class="quiz-option">';
                html += '<input type="radio" name="q_' + q.id + '" value="' + opt.replace(/"/g,'&quot;') + '" />';
                html += '<span>' + opt + '</span>';
                html += '</label>';
            });
        }
        html += '</div>';
    });
    html += '<button type="button" class="quiz-submit-btn" onclick="submitRandomQuiz()">' + __t('quiz-submit-btn') + '</button>';
    html += '</form>';
    content.innerHTML = html;
    window._quizQuestions = questions;
}

function submitRandomQuiz() {
    const form = document.getElementById('random-quiz-form');
    const answers = {};
    window._quizQuestions.forEach(q => {
        const input = form.querySelector('[name="q_' + q.id + '"]');
        if (q.type === 'fillin') {
            answers[q.id] = input ? input.value : '';
        } else {
            const checked = form.querySelector('[name="q_' + q.id + '"]:checked');
            answers[q.id] = checked ? checked.value : '';
        }
    });

    fetch('/Quiz/SubmitRandom', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: answers })
    })
    .then(r => r.json())
    .then(result => renderQuizResult(result))
    .catch(e => alert(__t('quiz-submit-failed') + e.message));
}

function renderQuizResult(result) {
    const content = document.getElementById('quiz-content');
    const pct = Math.round((result.score / result.total) * 100);
    const grade = pct >= 80 ? __t('quiz-grade-excellent') : pct >= 60 ? __t('quiz-grade-pass') : __t('quiz-grade-fail');

    let html = '<div class="quiz-result">';
    html += '<div class="result-circle" style="--pct:' + pct + '%"><span>' + result.score + '/' + result.total + '</span></div>';
    html += '<div class="result-grade">' + grade + ' (' + pct + '%)</div>';
    html += '</div>';

    result.details.forEach((d, i) => {
        const icon = d.isCorrect ? '✅' : '❌';
        html += '<div class="quiz-detail ' + (d.isCorrect ? 'correct' : 'wrong') + '">';
        html += '<div class="qd-head">' + icon + ' Q' + (i+1) + ': ' + d.questionText + '</div>';
        if (!d.isCorrect) {
            html += '<div class="qd-ans">' + __t('quiz-your-answer') + '<code>' + (d.yourAnswer || __t('quiz-no-answer')) + '</code></div>';
            html += '<div class="qd-correct">' + __t('quiz-correct-answer') + '<code>' + d.correctAnswer + '</code></div>';
        }
        html += '<div class="qd-explain">💡 ' + d.explanation + '</div>';
        html += '</div>';
    });

    html += '<button class="quiz-submit-btn" onclick="closeQuizModal()">' + __t('quiz-close-btn') + '</button>';
    content.innerHTML = html;
}

function closeQuizModal() {
    document.getElementById('quiz-modal').style.display = 'none';
    document.body.style.overflow = '';
}

// 用 ideas.js 的統一功能載入知識牆
loadIdeaWall();

// 載入老師免費分享
(function() {
    fetch('/Teacher/LatestPosts')
        .then(r => r.json())
        .then(posts => {
            var grid = document.getElementById('teacherPostsGrid');
            if (!posts || posts.length === 0) {
                grid.innerHTML = '<div style="color:var(--text-muted);font-size:13px;">' + __t('home-posts-empty') + '</div>';
                return;
            }
            var html = '';
            posts.forEach(function(p) {
                var typeName = p.type === 'video' ? '🎬 ' + __t('home-post-video') : p.type === 'resource' ? '📦 ' + __t('home-post-resource') : '📝 ' + __t('home-post-article');
                html += '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:20px;transition:border-color 0.2s;cursor:pointer;" onclick="window.location.href=\'/Teacher/Detail/' + p.teacherId + '\'">';
                html += '  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">';
                html += '    <span style="font-size:11px;padding:2px 10px;border-radius:10px;background:rgba(99,102,241,0.1);color:var(--accent);">' + typeName + '</span>';
                html += '    <span style="font-size:11px;color:var(--text-muted);">' + p.createdAt + '</span>';
                html += '  </div>';
                html += '  <div style="font-size:15px;font-weight:700;margin-bottom:8px;">' + p.title + '</div>';
                html += '  <div style="font-size:13px;color:var(--text-muted);line-height:1.5;margin-bottom:12px;">' + p.preview + '</div>';
                html += '  <div style="display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--text-muted);">';
                html += '    <span>👨‍🏫 ' + p.teacherName + '</span>';
                html += '    <span>❤️ ' + p.likes + ' ' + __t('home-post-likes') + '</span>';
                html += '  </div>';
                html += '  <div style="margin-top:10px;text-align:right;"><span style="font-size:13px;color:var(--accent);">' + __t('home-read-more') + ' &rarr;</span></div>';
                html += '</div>';
            });
            grid.innerHTML = html;
        })
        .catch(function() {
            document.getElementById('teacherPostsGrid').innerHTML = '<div style="color:var(--text-muted);font-size:13px;">' + __t('home-load-failed') + '</div>';
        });
})();
</script>
}
