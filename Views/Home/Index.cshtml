@model List<DotNetLearning.Models.Chapter>
@{
    ViewData["Title"] = ".NET 學習平台";

    // ── 核心路線（有順序的三大主軸）──
    var corePath = new[]
    {
        new { Key = "csharp",   Name = "C# 基礎",          Icon = "🔷", Color = "#9B59B6", Desc = "語言根基：變數、OOP、LINQ、非同步" },
        new { Key = "aspnet",   Name = "ASP.NET Core MVC",  Icon = "🌐", Color = "#3498DB", Desc = "Web 開發：路由、Controller、DI、API" },
        new { Key = "database", Name = "資料庫 & ORM",      Icon = "🗄️", Color = "#E74C3C", Desc = "資料層：SQL、EF Core、Dapper、優化" },
    };

    // ── 進階擴充（獨立模組）──
    var advancedModules = new Dictionary<string, (string Name, string Icon, string Color, string Desc)>
    {
        ["frontend"]       = ("前端基礎",          "🎨", "#E91E63", "HTML / CSS / JavaScript 與前後端整合"),
        ["git"]            = ("Git 版本控制",      "📝", "#F57C00", "版本管理、分支、GitHub 協作"),
        ["server"]         = ("架 Server 概念",    "🖥️", "#00897B", "Nginx、反向代理、負載平衡、監控"),
        ["patterns"]       = ("設計模式 & SOLID",  "🏛️", "#E67E22", "架構思維：SOLID、GoF、Clean Architecture"),
        ["infrastructure"] = ("快取 & 日誌 & 效能","⚡", "#9B59B6", "系統調校：Caching、Serilog、Profiling"),
        ["network"]        = ("網路 TCP/IP",       "🌍", "#27AE60", "通訊基礎：OSI、HTTP、DNS、WebSocket"),
        ["security"]       = ("資安",              "🔒", "#F39C12", "安全開發：JWT、加密、OWASP Top 10"),
        ["docker"]         = ("Docker & 部署",     "🐳", "#1ABC9C", "容器化：Docker、CI/CD、雲端部署"),
        ["ai"]             = ("AI 應用",           "🤖", "#FF6B6B", "AI 輔助：Prompt、MCP、Claude Code"),
        ["aimodel"]        = ("AI 模型與語言",     "🧠", "#7C4DFF", "LLM、RAG、Embedding、IPAS 知識"),
        ["claudecode"]     = ("Claude Code 工具",  "🔌", "#00BCD4", "不用 CMD 做專案、No-Code 流程"),
        ["project"]        = ("專案實戰",          "🛒", "#4CAF50", "電商、部落格、API 微服務完整開發"),
        ["iot"]            = ("IoT & POS 系統",    "🍓", "#FF5722", "Raspberry Pi、POS 開發、硬體整合"),
    };
}

<div class="home-layout">

    <!-- ══════════ Hero ══════════ -->
    <section class="hero" style="position:relative;background:linear-gradient(135deg, #0a1628 0%, #0f2027 30%, #203a43 60%, #2c5364 100%);overflow:hidden;">
        <canvas id="heroParticles" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;"></canvas>
        <div class="hero-bg" style="background:none;"></div>
        <div style="position:absolute;top:0;left:0;width:100%;height:100%;background-image:radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 1px);background-size:24px 24px;z-index:0;"></div>
        <div class="hero-content" style="position:relative;z-index:1;">
            <div class="hero-badge">完整 .NET 學習路徑</div>
            <h1>從零開始，<br><span class="highlight">完整學會 .NET</span></h1>
            <p class="hero-desc">
                C# / ASP.NET Core / 資料庫 / 設計模式 / Docker / AI<br>
                每章附詳細說明、程式碼範例、常見錯誤分析與隨機測驗
            </p>
            <div class="hero-cta">
                <a href="/Home/Chapter/csharp-intro" class="btn-cta-primary">開始學習</a>
                <a href="#quick-challenge" class="btn-cta-secondary">隨機挑戰</a>
                <a href="/Scores" class="btn-cta-ghost">成績總覽</a>
            </div>
            <div class="hero-stats">
                <div class="stat"><span class="stat-num clr-1">@Model.Count</span><small>章節內容</small></div>
                <div class="stat"><span class="stat-num clr-2">@(corePath.Length + advancedModules.Count)</span><small>主題分類</small></div>
                <div class="stat"><span class="stat-num clr-3">Free</span><small>完全免費</small></div>
            </div>
        </div>
    </section>

    <style>
        .floating-shape {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            opacity: 0.03;
        }
    </style>
    <div class="floating-shape" style="width:300px;height:300px;background:#00b894;top:20%;left:-100px;filter:blur(80px);"></div>
    <div class="floating-shape" style="width:400px;height:400px;background:#6366f1;bottom:10%;right:-150px;filter:blur(100px);"></div>
    <div class="floating-shape" style="width:200px;height:200px;background:#f59e0b;top:60%;left:50%;filter:blur(60px);"></div>

    <!-- ══════════ 開發者的話 ══════════ -->
    <section style="padding:40px 24px;max-width:900px;margin:0 auto;">
        <div style="background:linear-gradient(135deg, rgba(0,184,148,0.08), rgba(99,102,241,0.08));border:1px solid rgba(0,184,148,0.2);border-radius:16px;padding:32px;position:relative;overflow:hidden;">
            <div style="position:absolute;top:-20px;right:-20px;font-size:80px;opacity:0.05;">💻</div>
            <div style="display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;">
                <div style="flex-shrink:0;width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#00b894,#6366f1);display:flex;align-items:center;justify-content:center;font-size:24px;">👋</div>
                <div style="flex:1;min-width:280px;">
                    <h2 style="font-size:1.3rem;font-weight:700;margin:0 0 12px 0;color:var(--text);">嗨！我是 Mike，歡迎來到 DevLearn</h2>
                    <p style="color:var(--text-muted);line-height:1.8;margin:0 0 16px 0;font-size:0.92rem;">
                        這個平台是我的 Side Project，起因很簡單——<strong style="color:var(--accent);">學程式不應該無聊</strong>。
                        傳統的教學網站通常只有文字和程式碼，缺少互動和樂趣。所以我想做一個結合
                        <strong style="color:#6366f1;">遊戲化學習</strong>、<strong style="color:#6366f1;">老師媒合</strong>、
                        <strong style="color:#6366f1;">即時社群</strong>的學習平台，讓大家能邊玩邊學。
                    </p>
                    <p style="color:var(--text-muted);line-height:1.8;margin:0 0 16px 0;font-size:0.92rem;">
                        🤖 整個網站是我用 <strong style="color:var(--accent);">Claude Code（AI 輔助開發工具）</strong>從零打造的，
                        包括 93+ 章教學內容、12 種遊戲玩法、老師預約系統、即時聊天室，全部在短時間內完成。
                        這也證明了——善用 AI 工具，一個人也能做出完整的產品。
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;">
                        <span style="background:rgba(0,184,148,0.15);color:#00b894;padding:3px 10px;border-radius:20px;font-size:0.75rem;">ASP.NET Core 8</span>
                        <span style="background:rgba(99,102,241,0.15);color:#818cf8;padding:3px 10px;border-radius:20px;font-size:0.75rem;">PostgreSQL</span>
                        <span style="background:rgba(249,168,37,0.15);color:#F9A825;padding:3px 10px;border-radius:20px;font-size:0.75rem;">SignalR 即時通訊</span>
                        <span style="background:rgba(233,30,99,0.15);color:#E91E63;padding:3px 10px;border-radius:20px;font-size:0.75rem;">Azure 雲端</span>
                        <span style="background:rgba(0,188,212,0.15);color:#00BCD4;padding:3px 10px;border-radius:20px;font-size:0.75rem;">Claude Code AI</span>
                    </div>
                    <p style="color:var(--text-muted);line-height:1.8;margin:0 0 12px 0;font-size:0.92rem;">
                        🎥 試試左下角的<strong style="color:#8b5cf6;">「手勢控制」</strong>和<strong style="color:#ef4444;">「語音控制」</strong>！用手勢操控頁面，或直接說「找 LINQ」「下一章」「回首頁」就能導航。電腦用手勢、手機用頭部，還有語音指令。所有運算在本地完成，完全隱私安全。
                    </p>
                    <p style="color:var(--text-muted);line-height:1.8;margin:0 0 12px 0;font-size:0.92rem;">
                        📞 如果你在使用過程中遇到任何問題，或有想要的功能，歡迎透過右下角聊天室的<strong style="color:var(--accent);">「客服」分頁</strong>告訴我！
                        每一條建議我都會認真看。
                    </p>
                    <p style="color:var(--text);font-size:0.95rem;margin:0;font-weight:600;">
                        沒有壓力，按自己的節奏學習就好。希望大家在這裡開心學程式，一起成長！🚀
                    </p>
                    <p style="color:var(--text-muted);font-size:0.82rem;margin:12px 0 0 0;text-align:right;">
                        —— Mike（邱瀚賢）｜DevLearn 開發者
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════ 網站功能導覽 ══════════ -->
