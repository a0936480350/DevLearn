        </div>
    </section>

    <!-- ══════════ 隨機挑戰 ══════════ -->
    <section class="section-block" id="quick-challenge">
        <div class="section-header">
            <h2 class="section-title">隨機挑戰</h2>
            <p class="section-subtitle">不用看課程也能測實力！隨機抽題，看看你的程度</p>
        </div>
        <div class="challenge-box">
            <div class="challenge-options">
                <button class="challenge-btn" onclick="startRandomQuiz(5)">
                    <span class="cb-num">5</span>
                    <span class="cb-label">快速挑戰<br><small>3 分鐘</small></span>
                </button>
                <button class="challenge-btn" onclick="startRandomQuiz(10)">
                    <span class="cb-num">10</span>
                    <span class="cb-label">標準測驗<br><small>8 分鐘</small></span>
                </button>
                <button class="challenge-btn" onclick="startRandomQuiz(20)">
                    <span class="cb-num">20</span>
                    <span class="cb-label">完整挑戰<br><small>15 分鐘</small></span>
                </button>
            </div>
        </div>
    </section>

    <!-- ══════════ 知識分享牆 ══════════ -->
    <section class="section-block" id="idea-wall">
        <div class="section-header">
            <h2 class="section-title">知識分享牆</h2>
            <p class="section-subtitle">看看大家的學習心得、筆記和想法</p>
        </div>
        <div class="idea-wall-actions">
            <button class="btn-cta-primary" onclick="postGlobalIdea()" style="font-size:.88rem;padding:10px 22px;">分享你的想法</button>
        </div>
        <div id="globalIdeaWall" class="idea-wall-grid">
            <div class="idea-loading">載入中...</div>
        </div>
    </section>

    <!-- ══════════ 老師免費分享 ══════════ -->
    <section class="section-block" id="teacher-posts">
        <div class="section-header">
            <h2 class="section-title">老師免費分享</h2>
            <p class="section-subtitle">來自平台老師的最新免費文章、影片和資源</p>
        </div>
        <div id="teacherPostsGrid" class="idea-wall-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;">
            <div style="color:var(--text-muted);font-size:13px;">載入中...</div>
        </div>
    </section>

    <!-- ══════════ Footer ══════════ -->
    <footer class="px-footer">
        <div class="px-footer-inner">
            <div class="px-footer-brand">
                <div>
                    <div class="px-footer-title">DevLearn · .NET 學習平台</div>
                    <div class="px-footer-sub">.NET Developer Learning Platform</div>
                </div>
            </div>
            <div class="px-footer-links">
                <a href="/">首頁</a>
                <a href="/Leaderboard">排行榜</a>
