@{
    ViewData["Title"] = "付款結果";
    var orderId = (string)ViewBag.OrderId;
    var success = (bool)ViewBag.Success;
    var dbStatus = (string)ViewBag.DbStatus;
    var amount = (string?)ViewBag.Amount;
    var message = (string?)ViewBag.Message;
    Layout = "_Layout";
}

<div style="max-width:560px;margin:60px auto;padding:40px;background:#161b22;border:1px solid #30363d;border-radius:14px;color:#e6edf3;text-align:center;">
    @if (success && dbStatus == "paid")
    {
        <div style="font-size:64px;margin-bottom:12px;">✅</div>
        <h1 style="color:#3fb950;margin:0 0 14px;font-size:28px;">付款成功！</h1>
        <p style="color:#8b949e;line-height:1.7;">
            感謝你成為 DevLearn 首批 Premium 老師之一 🎉<br>
            你的老師帳號已經啟用，可以開始設定課程、接受學生預約。
        </p>
        <div style="margin:24px 0;padding:16px;background:#0d1117;border-radius:10px;text-align:left;font-size:14px;">
            <div style="color:#8b949e;">訂單編號</div>
            <div style="font-family:Consolas,monospace;color:#e6edf3;margin-bottom:10px;">@orderId</div>
            <div style="color:#8b949e;">金額</div>
            <div style="color:#e6edf3;">NT$ @amount</div>
        </div>
        <a href="/Teacher/MyProfile" style="display:inline-block;padding:12px 28px;background:linear-gradient(135deg,#238636,#2ea043);color:white;text-decoration:none;border-radius:8px;font-weight:700;margin-right:8px;">前往老師後台</a>
        <a href="/Payment/MySubscription" style="display:inline-block;padding:12px 28px;background:#21262d;color:#c9d1d9;text-decoration:none;border-radius:8px;font-weight:700;">我的訂閱</a>
    }
    else if (dbStatus == "paid")
    {
        <div style="font-size:64px;margin-bottom:12px;">⏳</div>
        <h1 style="color:#3fb950;margin:0 0 14px;">已完成</h1>
        <p style="color:#8b949e;">系統已經確認你的付款，訂閱已啟用。</p>
        <a href="/Payment/MySubscription" style="display:inline-block;padding:12px 28px;background:#238636;color:white;text-decoration:none;border-radius:8px;font-weight:700;margin-top:20px;">查看訂閱</a>
    }
    else if (dbStatus == "pending")
    {
        <div style="font-size:64px;margin-bottom:12px;">⏳</div>
        <h1 style="color:#f0c674;margin:0 0 14px;">處理中</h1>
        <p style="color:#8b949e;line-height:1.7;">
            瀏覽器收到了綠界的回應，但我們伺服器還沒收到正式確認。<br>
            通常幾秒內會更新，請過一下重新整理「我的訂閱」。
        </p>
        <a href="/Payment/MySubscription" style="display:inline-block;padding:12px 28px;background:#238636;color:white;text-decoration:none;border-radius:8px;font-weight:700;margin-top:20px;">重新整理訂閱狀態</a>
    }
    else
    {
        <div style="font-size:64px;margin-bottom:12px;">❌</div>
        <h1 style="color:#f85149;margin:0 0 14px;">付款失敗</h1>
        <p style="color:#8b949e;">
            @(string.IsNullOrEmpty(message) ? "付款未完成或被取消。" : message)
        </p>
        <div style="margin:24px 0;padding:16px;background:#0d1117;border-radius:10px;text-align:left;font-size:14px;">
            <div style="color:#8b949e;">訂單編號</div>
            <div style="font-family:Consolas,monospace;color:#e6edf3;">@orderId</div>
        </div>
        <a href="/Payment/SubscribeTeacher" style="display:inline-block;padding:12px 28px;background:#238636;color:white;text-decoration:none;border-radius:8px;font-weight:700;margin-right:8px;">重新付款</a>
        <a href="/Payment/MySubscription" style="display:inline-block;padding:12px 28px;background:#21262d;color:#c9d1d9;text-decoration:none;border-radius:8px;font-weight:700;">返回</a>
    }
</div>
