    <!-- 全方位錯誤自動偵測與回報 -->
    <script>
    (function(){
        var reported = {};
        function reportError(msg, stack, source) {
            var key = msg + '|' + location.pathname;
            if (reported[key]) return;
            reported[key] = true;
            fetch('/api/ErrorLog/report', {method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({pageUrl: location.href, errorMessage: msg, stackTrace: stack || '', source: source || 'frontend'})
            }).catch(function(){});
        }

        // 1. JS 執行錯誤
        window.onerror = function(msg, url, line, col, err) {
            reportError(msg, (err&&err.stack||'') + ' at ' + url + ':' + line + ':' + col, 'frontend-js');
        };

        // 2. Promise 未處理的 rejection
        window.addEventListener('unhandledrejection', function(e) {
            reportError('Unhandled Promise: ' + (e.reason&&e.reason.message||e.reason||''), e.reason&&e.reason.stack||'', 'frontend-promise');
        });

        // 3. API 呼叫失敗偵測（攔截 fetch）
        var origFetch = window.fetch;
        window.fetch = function(url, opts) {
            return origFetch.apply(this, arguments).then(function(res) {
                if (!res.ok && res.status >= 500) {
                    reportError('API 500: ' + (typeof url === 'string' ? url : url.url) + ' [' + res.status + ']', 'Status: ' + res.status + ' ' + res.statusText, 'frontend-api');
                }
                return res;
            }).catch(function(err) {
                reportError('API Network Error: ' + (typeof url === 'string' ? url : url.url), err&&err.message||'', 'frontend-network');
                throw err;
            });
        };

        // 4. 資源載入失敗（CSS/JS/圖片）
        window.addEventListener('error', function(e) {
            if (e.target && e.target !== window && e.target.tagName) {
                var tag = e.target.tagName;
                var src = e.target.src || e.target.href || '';
                if (src && (tag === 'SCRIPT' || tag === 'LINK' || tag === 'IMG')) {
                    reportError('Resource Load Failed: [' + tag + '] ' + src, '', 'frontend-resource');
                }
            }
        }, true);

        // 5. 頁面載入效能（超過 10 秒警告）
        window.addEventListener('load', function() {
            setTimeout(function() {
                if (window.performance) {
                    var timing = performance.timing;
                    var loadTime = timing.loadEventEnd - timing.navigationStart;
                    if (loadTime > 10000) {
                        reportError('Slow Page Load: ' + (loadTime/1000).toFixed(1) + 's on ' + location.pathname, 'domContentLoaded: ' + (timing.domContentLoadedEventEnd - timing.navigationStart) + 'ms', 'frontend-performance');
                    }
                }
            }, 100);
        });

        // 6. Console.error 攔截
        var origError = console.error;
        console.error = function() {
            var args = Array.prototype.slice.call(arguments);
            var msg = args.map(function(a){ return typeof a === 'string' ? a : JSON.stringify(a); }).join(' ');
            if (msg.length > 10 && !msg.includes('ErrorLog')) {
                reportError('Console.error: ' + msg.substring(0, 500), '', 'frontend-console');
            }
            origError.apply(console, arguments);
        };

        // 7. 手機端偵測
        var isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
        if (isMobile) {
            // 7a. 觸控無反應偵測（點按鈕 3 秒沒反應）
            document.addEventListener('touchstart', function(e) {
                var target = e.target.closest('button, a, [onclick]');
                if (!target) return;
                target._touchStart = Date.now();
            }, {passive: true});
            document.addEventListener('touchend', function(e) {
                var target = e.target.closest('button, a, [onclick]');
                if (!target || !target._touchStart) return;
                var elapsed = Date.now() - target._touchStart;
                if (elapsed > 3000) {
                    reportError('Mobile UI Freeze: ' + (target.textContent||'').substring(0,50) + ' (' + elapsed + 'ms)', 'Element: ' + target.tagName + '.' + target.className, 'mobile-freeze');
                }
                delete target._touchStart;
            }, {passive: true});

            // 7b. viewport 異常偵測（手機 zoom 被鎖定）
            if (window.visualViewport && window.visualViewport.scale > 1.5) {
                reportError('Mobile Zoom Issue: scale=' + window.visualViewport.scale, 'viewport width: ' + window.innerWidth, 'mobile-viewport');
            }

            // 7c. 離線偵測
            window.addEventListener('offline', function() {
                reportError('Mobile Offline: 使用者網路斷線', 'page: ' + location.pathname, 'mobile-network');
            });

            // 7d. 記憶體不足偵測（如果支援）
            if (navigator.deviceMemory && navigator.deviceMemory < 2) {
                reportError('Low Memory Device: ' + navigator.deviceMemory + 'GB', 'UA: ' + navigator.userAgent.substring(0, 100), 'mobile-memory');
            }
        }

        // 8. SignalR 斷線偵測
        var signalRChecked = false;
        setTimeout(function() {
            if (typeof signalR !== 'undefined' && !signalRChecked) {
                signalRChecked = true;
                // 如果 10 秒後 connection 還沒建立
                if (typeof connection !== 'undefined' && connection && connection.state !== 'Connected') {
                    reportError('SignalR Not Connected: state=' + (connection.state||'unknown'), '', 'signalr');
                }
            }
        }, 10000);
    })();
    </script>
