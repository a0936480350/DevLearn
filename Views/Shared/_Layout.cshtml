            <div>😤 <span style="color:#e2e8f0;">抬頭</span> → 頁面上捲</div>
            <div>😏 <span style="color:#e2e8f0;">頭向左偏</span> → 上一頁</div>
            <div>😏 <span style="color:#e2e8f0;">頭向右偏</span> → 下一頁</div>
            <div>😮 <span style="color:#e2e8f0;">張嘴</span> → 標記完成</div>
            <div>😳 <span style="color:#e2e8f0;">挑眉</span> → 回到頂部</div>
            <div style="margin-top:6px;font-size:10px;color:#64748b;">間隔 1 秒 ｜ 正對鏡頭 30-50cm</div>
        </div>
    </div>
</div>

<button id="voiceToggleBtn" onclick="toggleVoice()" style="
    position:fixed;bottom:20px;left:170px;z-index:9998;
    background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;
    border:none;border-radius:25px;padding:10px 18px;cursor:pointer;
    font-size:14px;font-weight:600;box-shadow:0 4px 15px rgba(239,68,68,0.4);
    display:flex;align-items:center;gap:6px;transition:all 0.3s;">
    🎤 語音控制
</button>

<div id="voiceStatus" style="
    position:fixed;bottom:60px;left:170px;z-index:9998;
    background:rgba(15,17,23,0.95);backdrop-filter:blur(20px);
    border:1px solid rgba(239,68,68,0.3);border-radius:12px;
    padding:10px 16px;display:none;font-size:13px;color:#e2e8f0;
    max-width:250px;">
    <div id="voiceText" style="margin-bottom:6px;color:#94a3b8;">🎤 聆聽中...</div>
    <div id="voiceResult" style="color:#00b894;font-weight:600;min-height:18px;"></div>
    <div style="font-size:10px;color:#4b5563;margin-top:4px;">說「說明」查看指令</div>
</div>

<style>
@@media (max-width: 600px) {
    #gestureToggleBtn { bottom: 80px !important; left: 10px !important; font-size: 12px !important; padding: 8px 14px !important; }
    #gesturePanel { bottom: 130px !important; left: 10px !important; width: 240px !important; }
    #voiceToggleBtn { bottom: 80px !important; left: 130px !important; font-size: 12px !important; padding: 8px 14px !important; }
    #voiceStatus { bottom: 130px !important; left: 10px !important; }
}
</style>

<script>
var gestureActive = false;
var gestureCamera = null;
var lastGestureTime = 0;
var lastHandX = null;
var gestureThrottle = 800;
var isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

// 跳頁後自動重連手勢控制
if (localStorage.getItem('gestureOn') === 'true') {
    setTimeout(function(){ toggleGesture(); }, 1500);
}
if (localStorage.getItem('voiceOn') === 'true') {
    setTimeout(function(){ toggleVoice(); }, 2000);
}

// Set button label and guide based on device
document.getElementById('gestureToggleBtnLabel').textContent = isMobile ? '頭部控制' : '手勢控制';
document.getElementById(isMobile ? 'headGuide' : 'handGuide').style.display = 'block';
document.getElementById('instructionText').textContent = isMobile
    ? '正對前置鏡頭，用頭部動作控制頁面。'
    : '將手舉到鏡頭前方約 30-50 公分處，系統會自動偵測手勢。';
document.getElementById('gesturePanelTitle').textContent = isMobile ? '🎥 頭部控制' : '🎥 手勢控制';

function toggleGesture() {
    var panel = document.getElementById('gesturePanel');
    var btn = document.getElementById('gestureToggleBtn');

    if (gestureActive) {
        gestureActive = false;
        localStorage.setItem('gestureOn', 'false');
        if (gestureCamera) gestureCamera.stop();
        var video = document.getElementById('gestureVideo');
        if (video.srcObject) {
            video.srcObject.getTracks().forEach(t => t.stop());
            video.srcObject = null;
        }
        panel.style.display = 'none';
        btn.style.background = 'linear-gradient(135deg,#6366f1,#8b5cf6)';
        btn.innerHTML = '🎥 ' + (isMobile ? '頭部控制' : '手勢控制');
        document.getElementById('gestureCursor').style.display = 'none';
        document.getElementById('cursorProgress').style.display = 'none';
        var cl = document.getElementById('cursorLabel'); if(cl) cl.style.display = 'none';
        return;
    }

    panel.style.display = 'block';
    btn.style.background = 'linear-gradient(135deg,#ef4444,#dc2626)';
    btn.innerHTML = '⏹ 停止';
    gestureActive = true;
    localStorage.setItem('gestureOn', 'true');

    var video = document.getElementById('gestureVideo');
    var canvas = document.getElementById('gestureCanvas');
    var ctx = canvas.getContext('2d');
    var statusEl = document.getElementById('gestureStatus');
    var actionEl = document.getElementById('gestureAction');

    if (isMobile) {
        // Use Face Mesh for head tracking
        var faceMesh = new FaceMesh({
            locateFile: (file) => `https://cdn.jsdelivr.net/npm/@@mediapipe/face_mesh@@0.4.1633559619/${file}`
        });

        faceMesh.setOptions({
            maxNumFaces: 1,
            refineLandmarks: true,
            minDetectionConfidence: 0.5,
            minTrackingConfidence: 0.5
        });

        var baseNoseY = null;
        var baseNoseX = null;
        var mouthOpenThreshold = 0.04;
        var headTiltThreshold = 0.03;
        var headNodThreshold = 0.04;

        faceMesh.onResults(function(results) {
            if (!gestureActive) return;

            canvas.width = video.videoWidth || 280;
            canvas.height = video.videoHeight || 210;
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            if (results.multiFaceLandmarks && results.multiFaceLandmarks.length > 0) {
                var face = results.multiFaceLandmarks[0];
                statusEl.textContent = '🙂 偵測到臉部';
                statusEl.style.color = '#00b894';

                // Draw face outline
                drawFaceOutline(ctx, face, canvas.width, canvas.height);

                // Key landmarks
                var noseTip = face[1];
                var chin = face[152];
                var forehead = face[10];
                var upperLip = face[13];
                var lowerLip = face[14];
                var leftEyeTop = face[159];
                var leftEyeBottom = face[145];
                var rightEyeTop = face[386];
                var rightEyeBottom = face[374];

                // Set baseline on first detection
                if (baseNoseY === null) {
                    baseNoseY = noseTip.y;
                    baseNoseX = noseTip.x;
                    return;
                }

                // Calculate head movements
                var nodAmount = noseTip.y - baseNoseY;
                var tiltAmount = noseTip.x - baseNoseX;

                // Mouth open detection
                var mouthOpen = Math.abs(upperLip.y - lowerLip.y);

                // Eye open detection (for eyebrow raise)
                var leftEyeOpen = Math.abs(leftEyeTop.y - leftEyeBottom.y);
                var rightEyeOpen = Math.abs(rightEyeTop.y - rightEyeBottom.y);
                var eyeOpen = (leftEyeOpen + rightEyeOpen) / 2;

                var gesture = null;

                // Detect gestures with throttle
                if (Date.now() - lastGestureTime > 1000) {
                    if (mouthOpen > mouthOpenThreshold) {
                        gesture = 'thumbsup';
                    }
                    else if (eyeOpen > 0.025) {
                        gesture = 'fist';
                    }
                    else if (nodAmount > headNodThreshold) {
                        gesture = 'point_down';
                    }
                    else if (nodAmount < -headNodThreshold) {
                        gesture = 'point_up';
                    }
                    else if (tiltAmount > headTiltThreshold) {
                        gesture = 'swipe_left';
                    }
                    else if (tiltAmount < -headTiltThreshold) {
                        gesture = 'swipe_right';
                    }

                    if (gesture) {
                        executeGesture(gesture, actionEl);
                        lastGestureTime = Date.now();
                        baseNoseY = noseTip.y;
                        baseNoseX = noseTip.x;
                    }
                }

                // Slowly drift baseline to adapt to head position changes
                baseNoseY = baseNoseY * 0.95 + noseTip.y * 0.05;
                baseNoseX = baseNoseX * 0.95 + noseTip.x * 0.05;

            } else {
                statusEl.textContent = '等待偵測臉部...';
                statusEl.style.color = '#94a3b8';
                baseNoseY = null;
                baseNoseX = null;
            }
        });

        gestureCamera = new Camera(video, {
            onFrame: async () => { if(gestureActive) await faceMesh.send({image: video}); },
            width: 280,
            height: 210
        });
        gestureCamera.start();

    } else {
        // Desktop: existing hand gesture code
        var hands = new Hands({
            locateFile: (file) => `https://cdn.jsdelivr.net/npm/@@mediapipe/hands@@0.4.1675469240/${file}`
        });

        hands.setOptions({
            maxNumHands: 2,
            modelComplexity: 0,
            minDetectionConfidence: 0.6,
            minTrackingConfidence: 0.5
        });

        hands.onResults(function(results) {
            if (!gestureActive) return;

            canvas.width = video.videoWidth || 280;
            canvas.height = video.videoHeight || 210;
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
                // ═══ 雙手比YA偵測 = 回首頁 ═══
                if (results.multiHandLandmarks.length >= 2) {
                    var h1 = results.multiHandLandmarks[0];
                    var h2 = results.multiHandLandmarks[1];
                    var h1idx = h1[8].y < h1[6].y;
                    var h1mid = h1[12].y < h1[10].y;
                    var h1ring = h1[16].y < h1[14].y;
                    var h2idx = h2[8].y < h2[6].y;
                    var h2mid = h2[12].y < h2[10].y;
                    var h2ring = h2[16].y < h2[14].y;
                    if (h1idx && h1mid && !h1ring && h2idx && h2mid && !h2ring) {
                        if (Date.now() - lastGestureTime > 1500) {
                            executeGesture('ok_home', actionEl);
                            lastGestureTime = Date.now();
                        }
                    }
                }

                var landmarks = results.multiHandLandmarks[0];
                statusEl.textContent = results.multiHandLandmarks.length > 1 ? '✌️✌️ 雙手偵測' : '✋ 偵測到手部';
                statusEl.style.color = '#00b894';

                drawHand(ctx, landmarks, canvas.width, canvas.height);

                var indexTip = landmarks[8];
                var wrist = landmarks[0];
                var cursorEl = document.getElementById('gestureCursor');
                var progressEl = document.getElementById('cursorProgress');
                var labelEl = document.getElementById('cursorLabel');

                // 只有食指在畫面內才移動游標（x: 0.05~0.95, y: 0.05~0.95）
                var inFrame = indexTip.x > 0.05 && indexTip.x < 0.95 && indexTip.y > 0.05 && indexTip.y < 0.95;

                if (inFrame) {
                    // 映射手指位置到螢幕（鏡像 X）
                    var screenX = (1 - indexTip.x) * window.innerWidth;
                    var screenY = indexTip.y * window.innerHeight;

                    // 平滑移動（減少抖動）
                    if (typeof window._smoothX === 'undefined') { window._smoothX = screenX; window._smoothY = screenY; }
                    // Minimum movement threshold to reduce jitter
                    var dx = Math.abs(screenX - window._smoothX);
                    var dyMove = Math.abs(screenY - window._smoothY);
                    if (dx > 5 || dyMove > 5) {
                        window._smoothX = window._smoothX * 0.75 + screenX * 0.25;
                        window._smoothY = window._smoothY * 0.75 + screenY * 0.25;
                    }

                    cursorEl.style.left = window._smoothX + 'px';
                    cursorEl.style.top = window._smoothY + 'px';
                    cursorEl.style.display = 'block';
                    labelEl.style.left = window._smoothX + 'px';
                    labelEl.style.top = window._smoothY + 'px';
                    labelEl.style.display = 'block';
                    progressEl.style.left = window._smoothX + 'px';
                    progressEl.style.top = window._smoothY + 'px';

                    // 偵測游標下方元素
                    cursorEl.style.display = 'none';
                    var hoveredEl = document.elementFromPoint(window._smoothX, window._smoothY);
                    cursorEl.style.display = 'block';

                    // 可點擊元素變橘色
                    if (hoveredEl) {
                        var link = hoveredEl.closest('a, button, [onclick]');
                        if (link) {
                            cursorEl.style.borderColor = '#f59e0b';
                            cursorEl.style.background = 'rgba(245,158,11,0.3)';
                            cursorEl.style.boxShadow = '0 0 25px rgba(245,158,11,0.6)';
                            labelEl.textContent = '🫳 靠近點擊';
                            labelEl.style.color = '#f59e0b';
                        } else {
                            cursorEl.style.borderColor = '#00b894';
                            cursorEl.style.background = 'rgba(0,184,148,0.25)';
                            cursorEl.style.boxShadow = '0 0 20px rgba(0,184,148,0.5)';
                            labelEl.textContent = '☝️ 移動中';
                            labelEl.style.color = '#00b894';
                        }
                    }

                    // 靠近鏡頭偵測（z 軸：手掌大小變大 = 靠近）
                    var palmSize = Math.sqrt(
                        Math.pow(landmarks[0].x - landmarks[9].x, 2) +
                        Math.pow(landmarks[0].y - landmarks[9].y, 2)
                    );
                    if (typeof window._basePalmSize === 'undefined') window._basePalmSize = palmSize;
                    window._basePalmSize = window._basePalmSize * 0.95 + palmSize * 0.05;

                    var pushRatio = palmSize / window._basePalmSize;

                    // 手掌放大 1.4 倍以上 = 靠近鏡頭 = 點擊
                    if (pushRatio > 1.4 && Date.now() - lastGestureTime > 1000) {
                        cursorEl.style.display = 'none';
                        var clickEl = document.elementFromPoint(window._smoothX, window._smoothY);
                        cursorEl.style.display = 'block';
                        if (clickEl) {
                            clickEl.style.outline = '3px solid #00b894';
                            clickEl.style.transition = 'outline 0.3s';
                            setTimeout(function(){ clickEl.style.outline = ''; }, 600);
                            clickEl.click();
                            var aLink = clickEl.closest('a');
                            if (aLink) window.location.href = aLink.href;
                        }
                        executeGesture('click', actionEl);
                        lastGestureTime = Date.now();
                        window._basePalmSize = palmSize;
                    }

                    // 進度環顯示靠近程度
                    if (pushRatio > 1.1) {
                        progressEl.style.display = 'block';
                        var progress = Math.min((pushRatio - 1.1) / 0.2, 1);
                        var circle = document.getElementById('cursorProgressCircle');
                        if (circle) circle.setAttribute('stroke-dashoffset', 113 - (113 * progress));
                    } else {
                        progressEl.style.display = 'none';
                    }

                    // 其他手勢（雙指捲動、OK回首頁、握拳回頂部）
                    var gesture = detectGesture(landmarks, window._smoothX, window._smoothY);
                    if (gesture && Date.now() - lastGestureTime > gestureThrottle) {
                        executeGesture(gesture, actionEl);
                        lastGestureTime = Date.now();
                    }
                }
                // 手出畫面 → 游標定點不動（不隱藏，保持最後位置）
                // 不做任何事，游標留在原位

            } else {
                // 完全沒偵測到手 → 也保持游標定點
                statusEl.textContent = '手離開了，游標已定點';
                statusEl.style.color = '#f59e0b';
            }
        });

        gestureCamera = new Camera(video, {
            onFrame: async () => { if(gestureActive) await hands.send({image: video}); },
            width: 280,
            height: 210
        });
        gestureCamera.start();
    }
}

function drawHand(ctx, landmarks, w, h) {
    var connections = [[0,1],[1,2],[2,3],[3,4],[0,5],[5,6],[6,7],[7,8],[5,9],[9,10],[10,11],[11,12],[9,13],[13,14],[14,15],[15,16],[13,17],[17,18],[18,19],[19,20],[0,17]];
    ctx.strokeStyle = 'rgba(99,102,241,0.6)';
    ctx.lineWidth = 2;
    connections.forEach(function(c) {
        ctx.beginPath();
        ctx.moveTo(landmarks[c[0]].x * w, landmarks[c[0]].y * h);
        ctx.lineTo(landmarks[c[1]].x * w, landmarks[c[1]].y * h);
        ctx.stroke();
    });

    landmarks.forEach(function(lm, i) {
        ctx.beginPath();
        ctx.arc(lm.x * w, lm.y * h, i === 8 ? 5 : 3, 0, 2 * Math.PI);
        ctx.fillStyle = i === 8 ? '#00b894' : '#6366f1';
        ctx.fill();
    });
}

function drawFaceOutline(ctx, face, w, h) {
    var facePoints = [10, 338, 297, 332, 284, 251, 389, 356, 454, 323, 361, 288, 397, 365, 379, 378, 400, 377, 152, 148, 176, 149, 150, 136, 172, 58, 132, 93, 234, 127, 162, 21, 54, 103, 67, 109];
    ctx.strokeStyle = 'rgba(99,102,241,0.4)';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    facePoints.forEach(function(idx, i) {
        var p = face[idx];
        if (i === 0) ctx.moveTo(p.x * w, p.y * h);
        else ctx.lineTo(p.x * w, p.y * h);
    });
    ctx.closePath();
    ctx.stroke();

    // Draw nose tip indicator
    var nose = face[1];
    ctx.beginPath();
    ctx.arc(nose.x * w, nose.y * h, 5, 0, 2 * Math.PI);
    ctx.fillStyle = '#00b894';
    ctx.fill();
}

function detectGesture(lm, screenX, screenY) {
    var wrist = lm[0];
    var thumbTip = lm[4];
    var thumbIp = lm[3];
    var indexTip = lm[8];
    var indexPip = lm[6];
    var indexMcp = lm[5];
    var middleTip = lm[12];
    var middlePip = lm[10];
    var middleMcp = lm[9];
    var ringTip = lm[16];
    var ringPip = lm[14];
    var ringMcp = lm[13];
    var pinkyTip = lm[20];
    var pinkyPip = lm[18];
    var pinkyMcp = lm[17];

    // 用 tip vs pip 比較（更準確）
    var indexUp = indexTip.y < indexPip.y;
    var middleUp = middleTip.y < middlePip.y;
    var ringUp = ringTip.y < ringPip.y;
    var pinkyUp = pinkyTip.y < pinkyPip.y;
    var thumbUp = thumbTip.y < thumbIp.y;
    var thumbOut = Math.abs(thumbTip.x - indexMcp.x) > 0.06;

    // 計算伸出的手指數量
    var fingersUp = (indexUp?1:0) + (middleUp?1:0) + (ringUp?1:0) + (pinkyUp?1:0);

    // ═══ 1. 靠近鏡頭 = 點擊（在 onResults 裡處理，這裡不重複）═══

    // ═══ 2. ✌️✌️ 雙手比YA = 回首頁（用兩隻手偵測改為：食指+中指都伸+無名小指收+拇指收）═══
    // 因為 MediaPipe 設定 maxNumHands=1，無法偵測雙手
    // 改成：比OK（拇指碰食指）= 回首頁
    var thumbToIndex = Math.sqrt(
        Math.pow(thumbTip.x - indexTip.x, 2) +
        Math.pow(thumbTip.y - indexTip.y, 2)
    );
    if (thumbToIndex < 0.04 && !middleUp && !ringUp && !pinkyUp) {
        return 'ok_home';
    }

    // ═══ 3. ✊ 握拳 = 回到頂部 ═══
    if (!indexUp && !middleUp && !ringUp && !pinkyUp && !thumbOut) {
        return 'fist';
    }

    // ═══ 4. ✌️ 兩指上下 = 觸控板雙指捲動 ═══
    if (indexUp && middleUp && !ringUp && !pinkyUp) {
        // 追蹤兩指的 Y 軸移動方向
        var twoFingerY = (indexTip.y + middleTip.y) / 2;
        if (typeof window._lastTwoFingerY === 'undefined') window._lastTwoFingerY = null;

        if (window._lastTwoFingerY !== null) {
            var dy = twoFingerY - window._lastTwoFingerY;
            if (dy > 0.04) {
                window._lastTwoFingerY = twoFingerY;
                return 'scroll_down';
            }
            if (dy < -0.04) {
                window._lastTwoFingerY = twoFingerY;
                return 'scroll_up';
            }
        }
        window._lastTwoFingerY = twoFingerY;
        return null; // 兩指靜止不觸發
    } else {
        window._lastTwoFingerY = null;
    }

    // ═══ 5. 🤟 三指左右揮 = 上下頁 ═══
    if (indexUp && middleUp && ringUp && !pinkyUp) {
        var currentX = wrist.x;
        if (typeof window._lastThreeFingerX === 'undefined') window._lastThreeFingerX = null;

        if (window._lastThreeFingerX !== null) {
            var dx = currentX - window._lastThreeFingerX;
            if (dx > 0.08) { window._lastThreeFingerX = currentX; return 'swipe_left'; }
            if (dx < -0.08) { window._lastThreeFingerX = currentX; return 'swipe_right'; }
        }
        window._lastThreeFingerX = currentX;
        return null;
    } else {
        window._lastThreeFingerX = null;
    }

    // ═══ 6. ✋ 五指張開不動 = 暫停 3 秒 ═══
    if (indexUp && middleUp && ringUp && pinkyUp) {
        return 'palm';
    }

    // ═══ 7. ☝️ 一指 = 移動游標（不觸發其他動作）═══
    if (indexUp && !middleUp && !ringUp && !pinkyUp) {
        return null; // 純游標移動，不觸發任何動作
    }

    lastHandX = wrist.x;
    return null;
}

function executeGesture(gesture, actionEl) {
    var msg = '';
    switch(gesture) {
        case 'point_up':
        case 'scroll_up':
            window.scrollBy({ top: -300, behavior: 'smooth' });
            msg = '✌️⬆ 上捲';
            break;
        case 'point_down':
        case 'scroll_down':
            window.scrollBy({ top: 300, behavior: 'smooth' });
            msg = '✌️⬇ 下捲';
            break;
        case 'swipe_left':
            var prevBtn = document.querySelector('.prev-link');
            if (prevBtn) prevBtn.click();
            else history.back();
            msg = '👈 上一頁';
            break;
        case 'swipe_right':
            var nextBtn = document.querySelector('.next-link');
            if (nextBtn) nextBtn.click();
            else history.forward();
            msg = '👉 下一頁';
            break;
        case 'palm':
            msg = '✋ 暫停偵測 3 秒';
            gestureThrottle = 3000;
            setTimeout(function(){ gestureThrottle = 800; }, 3000);
            break;
        case 'click':
            msg = '👍 點擊！';
            break;
        case 'ok_home':
            window.location.href = '/';
            msg = '👌 回首頁';
            break;
        case 'fist':
            window.scrollTo({ top: 0, behavior: 'smooth' });
            msg = '✊ 回到頂部';
            break;
    }

    if (msg) {
        actionEl.textContent = msg;
        actionEl.style.display = 'block';
        setTimeout(function(){ actionEl.style.display = 'none'; }, 1500);
    }
}

var voiceActive = false;
var recognition = null;
var voiceInputMode = false;   // 語音打字模式
var voiceInputTarget = null;  // 目前要填入的 input

function toggleVoice() {
    var btn = document.getElementById('voiceToggleBtn');
    var status = document.getElementById('voiceStatus');

    if (voiceActive) {
        voiceActive = false;
        voiceInputMode = false;
        localStorage.setItem('voiceOn', 'false');
        if (recognition) recognition.stop();
        btn.style.background = 'linear-gradient(135deg,#ef4444,#dc2626)';
        btn.innerHTML = '🎤 語音控制';
        status.style.display = 'none';
        return;
    }

    var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
        alert('你的瀏覽器不支援語音辨識，請使用 Chrome 或 Safari');
        return;
    }

    voiceActive = true;
    localStorage.setItem('voiceOn', 'true');
    btn.style.background = 'linear-gradient(135deg,#22c55e,#16a34a)';
    btn.innerHTML = '🎤 聆聽中...';
    status.style.display = 'block';

    recognition = new SpeechRecognition();
    recognition.continuous = true;
    recognition.interimResults = true;
    recognition.lang = 'zh-TW';

    var abortCount = 0;
    var everStarted = false;

    recognition.onstart = function() {
        everStarted = true;
        abortCount = 0;
        document.getElementById('voiceText').textContent = '🎙️ 聆聽中，請說話...';
    };

    recognition.onsoundstart = function() {
        document.getElementById('voiceText').textContent = '🎤 偵測到聲音...';
    };

    recognition.onresult = function(event) {
        abortCount = 0;
        var interim = '', final = '';
        for (var i = event.resultIndex; i < event.results.length; i++) {
            var t = event.results[i][0].transcript;
            if (event.results[i].isFinal) final += t;
            else interim += t;
        }
        var display = final || interim;
        document.getElementById('voiceText').textContent = '🎤 ' + display;
        if (final) processVoiceCommand(final.trim());
    };

    recognition.onerror = function(e) {
        if (e.error === 'no-speech') return;
        var txt = document.getElementById('voiceText');
        if (e.error === 'not-allowed') {
            txt.textContent = '❌ 請在瀏覽器允許麥克風權限後重試';
            toggleVoice();
        } else if (e.error === 'aborted') {
            abortCount++;
            if (abortCount >= 3) {
                txt.textContent = '⚠️ 麥克風無法啟動，請確認權限或重新整理頁面';
            }
        } else if (e.error === 'network') {
            txt.textContent = '⚠️ 網路問題，重試中...';
        } else {
            txt.textContent = '❌ ' + e.error;
        }
    };

    recognition.onend = function() {
        if (voiceActive) {
            var delay = (abortCount > 0) ? 800 : 100;
            setTimeout(function() {
                if (voiceActive && abortCount < 5) {
                    try { recognition.start(); } catch(e) {}
                } else if (abortCount >= 5) {
                    document.getElementById('voiceText').textContent = '❌ 麥克風無法使用，請重新整理頁面';
                    toggleVoice();
                }
            }, delay);
        }
    };

    recognition.start();
}

// ── 工具函數 ──────────────────────────────────────────
function voiceMsg(msg, color) {
    var el = document.getElementById('voiceResult');
    el.style.color = color || '#00b894';
    el.textContent = msg;
    clearTimeout(el._t);
    el._t = setTimeout(function(){ el.textContent = ''; }, 4000);
}

// 正規化文字：去空白、全轉簡體常見替換、統一
function voiceNorm(s) {
    return s.replace(/\s+/g, '').toLowerCase()
        .replace(/登录/g,'登入').replace(/搜索/g,'搜尋')
        .replace(/帮我/g,'幫我').replace(/请/g,'請')
        .replace(/我想要/g,'我要').replace(/我想/g,'我要');
}

// 計算兩字串相似度（含字元覆蓋率）
function voiceSim(a, b) {
    a = voiceNorm(a); b = voiceNorm(b);
    if (b.includes(a) || a.includes(b)) return 1;
    var match = 0;
    for (var i = 0; i < a.length; i++) {
        if (b.includes(a[i])) match++;
    }
    return match / Math.max(a.length, 1);
}

// 找頁面上最相符的輸入欄位（by label/placeholder/name/aria-label）
function findBestInput(keyword) {
    keyword = voiceNorm(keyword);
    var inputs = Array.from(document.querySelectorAll(
        'input[type="text"], input[type="email"], input[type="number"], input[type="search"], input[type="tel"], textarea, input:not([type="hidden"]):not([type="submit"]):not([type="button"]):not([type="checkbox"]):not([type="radio"])'
    )).filter(function(el) {
        var rect = el.getBoundingClientRect();
        return rect.width > 0 && rect.height > 0 && !el.readOnly && !el.disabled && !el.closest('#voiceStatus');
    });

    var best = null, bestScore = 0;
    inputs.forEach(function(el) {
        var labelText = '';
        if (el.id) {
            var lbl = document.querySelector('label[for="' + el.id + '"]');
            if (lbl) labelText = lbl.textContent;
        }
        var parts = voiceNorm(labelText + ' ' + (el.placeholder||'') + ' ' + (el.name||'') + ' ' + (el.getAttribute('aria-label')||'') + ' ' + (el.title||''));
        var score = voiceSim(keyword, parts);
        if (parts.includes(keyword) || keyword.includes(parts.replace(/\s/g,''))) score = Math.max(score, 0.85);
        if (score > bestScore && score >= 0.25) { bestScore = score; best = el; }
    });
    return best;
}

// 找頁面上最相符的可點擊元素
function findBestClickable(keyword) {
    keyword = voiceNorm(keyword);
    var candidates = Array.from(document.querySelectorAll(
        'button:not([disabled]), a[href], input[type="submit"], input[type="button"], [role="button"]'
    )).filter(function(el) {
        var rect = el.getBoundingClientRect();
        return rect.width > 0 && rect.height > 0 &&
               !el.closest('#voiceStatus') && !el.closest('#voiceToggleBtn');
    });

    var best = null, bestScore = 0;
    candidates.forEach(function(el) {
        var label = voiceNorm(el.textContent || el.value || el.title || el.getAttribute('aria-label') || '');
        if (!label) return;
        var score = voiceSim(keyword, label);
        // 完全包含加分
        if (label.includes(keyword) || keyword.includes(label)) score = Math.max(score, 0.9);
        if (score > bestScore && score >= 0.4) { bestScore = score; best = el; }
    });
    return best;
}

// 找頁面上最相符的連結（文章/章節）
function findBestLink(keyword) {
    keyword = voiceNorm(keyword);
    var links = Array.from(document.querySelectorAll('a[href]')).filter(function(a) {
        return a.href && !a.href.startsWith('javascript') &&
               a.textContent.trim().length > 1;
    });
    var best = null, bestScore = 0;
    links.forEach(function(a) {
        var label = voiceNorm(a.textContent);
        var score = voiceSim(keyword, label);
        if (label.includes(keyword)) score = Math.max(score, 0.85);
        if (score > bestScore && score >= 0.4) { bestScore = score; best = a; }
    });
    return best;
}

// 填入當前焦點的 input，或指定 selector
function voiceFillInput(selector, value) {
    var el = selector
        ? (typeof selector === 'string' ? document.querySelector(selector) : selector)
        : (voiceInputTarget || document.activeElement);
    if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA')) {
        el.value = value;
        el.dispatchEvent(new Event('input', { bubbles: true }));
        el.dispatchEvent(new Event('change', { bubbles: true }));
        return true;
    }
    return false;
}

// ── 主要命令處理 ────────────────────────────────────────
function processVoiceCommand(rawText) {
    var text = voiceNorm(rawText);
    console.log('[Voice]', rawText, '→', text);

    // ── 語音打字模式：任何話都填入目標框 ──
    if (voiceInputMode && voiceInputTarget) {
        voiceInputTarget.value = rawText.trim();
        voiceInputTarget.dispatchEvent(new Event('input', { bubbles: true }));
        voiceMsg('✏️ 已填入: ' + rawText.trim());
        // 說「確定」「送出」「完成」退出打字模式
        if (/確定|送出|完成|好了|ok|OK/.test(rawText)) {
            voiceInputMode = false;
            voiceInputTarget = null;
            voiceMsg('✅ 完成輸入');
        }
        return;
    }

    // ── 選擇輸入框 (說「選擇XX輸入框」/「到XX欄位」/「選XX欄」) ──
    var selectInputMatch = rawText.match(/(?:選擇|選|到|點開|切換到|跳到)\s*(.{1,10}?)\s*(?:輸入框|欄位|欄|框|input)/i);
    if (!selectInputMatch) selectInputMatch = rawText.match(/(?:輸入框|欄位|框)\s*(.{1,10})/i);
    if (selectInputMatch) {
        var inputKeyword = voiceNorm(selectInputMatch[1]);
        var targetInput = findBestInput(inputKeyword);
        if (targetInput) {
            targetInput.focus();
            voiceInputTarget = targetInput;
            var inputLabel = targetInput.placeholder || targetInput.name || inputKeyword;
            voiceMsg('✅ 已選擇「' + inputLabel + '」輸入框，請說「輸入XXX」');
        } else {
            voiceMsg('❓ 找不到「' + selectInputMatch[1] + '」欄位');
        }
        return;
    }

    // ── 直接輸入（說「輸入XXX」/「填入XXX」/「打XXX」）──
    var fillMatch = rawText.match(/^(?:輸入|填入|填|打入|打)\s*(.+)/);
    if (fillMatch) {
        var fillValue = fillMatch[1].trim();
        var fillTarget = voiceInputTarget || document.activeElement;
        if (fillTarget && (fillTarget.tagName === 'INPUT' || fillTarget.tagName === 'TEXTAREA') && !fillTarget.readOnly && !fillTarget.disabled) {
            fillTarget.value = fillValue;
            fillTarget.dispatchEvent(new Event('input', {bubbles:true}));
            fillTarget.dispatchEvent(new Event('change', {bubbles:true}));
            var fillLabel = fillTarget.placeholder || fillTarget.name || '欄位';
            voiceMsg('✏️ 已在「' + fillLabel + '」輸入: ' + fillValue);
        } else {
            // Try to find any visible input
            var anyInput = document.querySelector('input[type="text"]:not([readonly]):not([disabled]), textarea:not([readonly]):not([disabled])');
            if (anyInput) {
                anyInput.focus();
                anyInput.value = fillValue;
                anyInput.dispatchEvent(new Event('input', {bubbles:true}));
                voiceInputTarget = anyInput;
                voiceMsg('✏️ 已輸入: ' + fillValue);
            } else {
                voiceMsg('❓ 請先說「選擇XX輸入框」選擇欄位');
            }
        }
        return;
    }

    // ── 在XX輸入YYY（一句話選擇並輸入）──
    var inFieldMatch = rawText.match(/在\s*(.{1,10}?)\s*(?:輸入框|欄位|欄|框)?\s*(?:輸入|填入|打)\s*(.+)/);
    if (inFieldMatch) {
        var fieldName = voiceNorm(inFieldMatch[1]);
        var fieldValue = inFieldMatch[2].trim();
        var targetField = findBestInput(fieldName);
        if (targetField) {
            targetField.focus();
            targetField.value = fieldValue;
            targetField.dispatchEvent(new Event('input', {bubbles:true}));
            voiceInputTarget = targetField;
            var fLabel = targetField.placeholder || targetField.name || inFieldMatch[1];
            voiceMsg('✏️ 已在「' + fLabel + '」輸入: ' + fieldValue);
        } else {
            voiceMsg('❓ 找不到「' + inFieldMatch[1] + '」欄位');
        }
        return;
    }

    // ── 清空欄位（說「清空XX」/「清除內容」） ──
    var clearMatch = rawText.match(/(?:清空|清除|刪除內容|清掉)\s*(.{0,10})/);
    if (clearMatch) {
        var clearTarget = voiceInputTarget || document.activeElement;
        if (clearTarget && (clearTarget.tagName === 'INPUT' || clearTarget.tagName === 'TEXTAREA')) {
            clearTarget.value = '';
            clearTarget.dispatchEvent(new Event('input', {bubbles:true}));
            voiceMsg('🗑️ 已清空欄位');
        } else {
            voiceMsg('❓ 請先選擇輸入框');
        }
        return;
    }

    // ── 語音填入帳號/密碼 (pattern: 帳號是XXX / 密碼是XXX / 輸入帳號XXX) ──
    var accountMatch = rawText.match(/帳號(?:是|為|輸入|打)?[：:\s]*(.+)/);
    var passwordMatch = rawText.match(/密碼(?:是|為|輸入|打)?[：:\s]*(.+)/);
    if (accountMatch) {
        var val = accountMatch[1].trim();
        var inp = document.querySelector('input[name="username"],input[name="Username"],input[type="text"]#username,input#Username');
        if (!inp) inp = document.querySelector('input[type="text"]:not([readonly])');
        if (inp) { inp.value = val; inp.dispatchEvent(new Event('input',{bubbles:true})); voiceMsg('👤 帳號: ' + val); }
        else voiceMsg('❓ 找不到帳號欄位');
        return;
    }
    if (passwordMatch) {
        var val2 = passwordMatch[1].trim();
        var inp2 = document.querySelector('input[type="password"]');
        if (inp2) { inp2.value = val2; inp2.dispatchEvent(new Event('input',{bubbles:true})); voiceMsg('🔒 密碼已填入'); }
        else voiceMsg('❓ 找不到密碼欄位');
        return;
    }

    // ── 語音打字模式觸發 ──
    if (/語音輸入|語音打字|用說的輸入|聲音輸入/.test(text)) {
        var focused = document.activeElement;
        if (focused && (focused.tagName === 'INPUT' || focused.tagName === 'TEXTAREA')) {
            voiceInputTarget = focused;
            voiceInputMode = true;
            voiceMsg('✏️ 語音打字模式：請說內容，說「確定」結束');
        } else {
            // 找第一個可見 input
            var inp3 = document.querySelector('input[type="text"]:not([readonly]),textarea');
            if (inp3) {
                inp3.focus();
                voiceInputTarget = inp3;
                voiceInputMode = true;
                voiceMsg('✏️ 語音打字模式：請說內容，說「確定」結束');
            } else {
                voiceMsg('❓ 找不到可輸入的欄位');
            }
        }
        return;
    }

    // ── 搜尋/找章節 ──
    var searchMatch = rawText.match(/(?:找|搜尋|搜索|幫我找|我要找|找一下|讀|打開|看)\s*(.+)/);
    if (searchMatch || /找|搜尋/.test(text)) {
        var keyword = searchMatch ? voiceNorm(searchMatch[1]) : text.replace(/找|搜尋|搜索|幫我|我要/g,'').trim();
        if (keyword.length > 0) {
            // 先找頁面連結
            var link = findBestLink(keyword);
            if (link) {
                voiceMsg('📖 前往: ' + link.textContent.trim().substring(0,20));
                setTimeout(function(){ link.click(); }, 500);
                return;
            }
            // 再找搜尋框
            var si = document.querySelector('#globalSearch,#sidebarSearch,.search-input,input[type="search"]');
            if (si) {
                si.value = searchMatch ? searchMatch[1].trim() : keyword;
                si.dispatchEvent(new Event('input',{bubbles:true}));
                si.focus();
                voiceMsg('🔍 搜尋: ' + keyword);
            } else {
                window.location.href = '/?q=' + encodeURIComponent(searchMatch ? searchMatch[1].trim() : keyword);
                voiceMsg('🔍 搜尋: ' + keyword);
            }
            return;
        }
    }

    // ── 點擊按鈕（說「點XXX」/「按XXX」/「點擊XXX」） ──
    var clickMatch = rawText.match(/(?:點|按|點擊|點一下|按下|按一下)\s*(.+)/);
    if (clickMatch) {
        var btnKeyword = clickMatch[1].trim();
        var el = findBestClickable(btnKeyword);
        if (el) {
            voiceMsg('👆 點擊: ' + (el.textContent||el.value||'').trim().substring(0,15));
            setTimeout(function(){ el.click(); }, 300);
        } else {
            voiceMsg('❓ 找不到按鈕: ' + btnKeyword);
        }
        return;
    }

    // ── 頁面導航 ──
    var nav = {
        '首頁|回首頁|回家|home':         ['/','🏠 首頁'],
        '登入|登錄|login|sign in':        ['/Account/Login','🔑 登入'],
        '註冊|register|sign up':          ['/Account/Register','📝 註冊'],
        '登出|logout|sign out':           ['/Account/Logout','🚪 登出'],
        '個人資料|個人頁|我的頁面|profile': ['/Account/Profile','👤 個人頁'],
        '老師|找老師|teacher':            ['/Teacher','👨‍🏫 找老師'],
        '簽到|check in|打卡':             ['/CheckIn','📅 簽到'],
        '排行|排名|leaderboard':          ['/Leaderboard','🏆 排行榜'],
        '每日|今日一題|daily':            ['/Daily','📅 每日一題'],
        '速度|speed|挑戰':               ['/Speed','⏱️ 速度挑戰'],
        '偵探|detective|找錯':           ['/Detective','🔍 偵探'],
        '分析|analytics|統計':           ['/Analytics','📊 分析'],
        '問答|qna|問題':                  ['/QnA','❓ 問答'],
        '擂台|arena|比賽':               ['/Arena','⚔️ 擂台'],
        '卡片|flashcard|暗記':           ['/Flashcard','🃏 卡片'],
        '片段|snippet|程式碼收藏':        ['/Snippet','📋 片段'],
        '謎題|puzzle|填字':              ['/Puzzle','🧩 謎題'],
        '好友|buddy|夥伴':               ['/Buddy','👫 好友'],
        '成績|scores|分數':              ['/Scores','📊 成績'],
    };
    for (var pattern in nav) {
        var re = new RegExp(pattern);
        if (re.test(text) || re.test(rawText)) {
            window.location.href = nav[pattern][0];
            voiceMsg(nav[pattern][1]);
            return;
        }
    }

    // ── 頁面操作 ──
    if (/往下|下捲|下面|繼續看|scroll down/.test(text)) { window.scrollBy({top:500,behavior:'smooth'}); voiceMsg('⬇️ 往下捲'); return; }
    if (/往上|上捲|上面|scroll up/.test(text)) { window.scrollBy({top:-500,behavior:'smooth'}); voiceMsg('⬆️ 往上捲'); return; }
    if (/頂部|最上面|回到頂部|top/.test(text)) { window.scrollTo({top:0,behavior:'smooth'}); voiceMsg('⬆️ 回頂部'); return; }
    if (/最下面|底部|bottom/.test(text)) { window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'}); voiceMsg('⬇️ 到底部'); return; }
    if (/下一章|下一頁|next/.test(text)) {
        var n = document.querySelector('.nav-next, a[class*="next"]');
        if (n) { voiceMsg('➡️ 下一章'); setTimeout(function(){ n.click(); },300); } else voiceMsg('❓ 沒有下一章');
        return;
    }
    if (/上一章|上一頁|prev|previous/.test(text)) {
        var p = document.querySelector('.nav-prev, a[class*="prev"]');
        if (p) { voiceMsg('⬅️ 上一章'); setTimeout(function(){ p.click(); },300); } else { history.back(); voiceMsg('⬅️ 上一頁'); }
        return;
    }
    if (/測驗|quiz|考試/.test(text)) {
        var qBtn = document.querySelector('[onclick*="openQuiz"],.btn-quiz');
        if (qBtn) { qBtn.click(); voiceMsg('🎯 開始測驗'); } else voiceMsg('❓ 目前頁面沒有測驗');
        return;
    }
    if (/練習|practice/.test(text)) {
        var pBtn = document.querySelector('[onclick*="openPractice"]');
        if (pBtn) { pBtn.click(); voiceMsg('⌨️ 開始練習'); } else voiceMsg('❓ 目前頁面沒有練習');
        return;
    }
    if (/標記完成|已完成|complete|完成/.test(text)) {
        var dBtn = document.querySelector('[onclick*="markComplete"],.btn-done');
        if (dBtn) { dBtn.click(); voiceMsg('✅ 標記完成'); } else voiceMsg('❓ 找不到完成按鈕');
        return;
    }
    if (/說明|幫助|help|指令|有什麼功能/.test(text)) {
        voiceMsg('📖 可說：選擇搜尋輸入框、輸入hello、在標題輸入XXX、找LINQ、點登入、帳號是xxx、往下...', '#F9A825');
        return;
    }

    // ── 最後嘗試：在頁面按鈕/連結中找最相符的 ──
    var anyEl = findBestClickable(rawText);
    if (anyEl) {
        var label = (anyEl.textContent || anyEl.value || '').trim().substring(0,20);
        voiceMsg('👆 ' + label);
        setTimeout(function(){ anyEl.click(); }, 400);
        return;
    }
    var anyLink = findBestLink(rawText);
    if (anyLink) {
        voiceMsg('📖 ' + anyLink.textContent.trim().substring(0,20));
        setTimeout(function(){ anyLink.click(); }, 400);
        return;
    }

    voiceMsg('🤔 沒聽懂，試試說「說明」看指令', '#F9A825');
}
</script>

