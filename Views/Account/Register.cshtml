@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>註冊 — .NET 學習平台</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background: #0d1117;
            color: #e6edf3;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .form-card {
            background: linear-gradient(135deg, #161b22, #1c2333);
            border: 1px solid #30363d;
            border-radius: 16px;
            padding: 40px 32px;
            width: 100%;
            max-width: 420px;
            margin: 20px;
        }
        .form-title {
            font-size: 24px;
            font-weight: 800;
            text-align: center;
            margin-bottom: 8px;
        }
        .form-subtitle {
            font-size: 14px;
            color: #8b949e;
            text-align: center;
            margin-bottom: 28px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #8b949e;
            margin-bottom: 6px;
        }
        .form-group input {
            width: 100%;
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid #30363d;
            background: #0d1117;
            color: #e6edf3;
            font-size: 15px;
            font-family: 'Noto Sans TC', sans-serif;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-group input:focus {
            border-color: #2299dd;
        }
        .btn-submit {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: none;
            background: #2299dd;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Noto Sans TC', sans-serif;
            transition: background 0.2s;
            margin-top: 8px;
        }
        .btn-submit:hover { background: #1a7fc4; }
        .error-msg {
            background: rgba(248, 81, 73, 0.15);
            color: #f85149;
            border: 1px solid rgba(248, 81, 73, 0.3);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            margin-bottom: 16px;
            text-align: center;
        }
        .links {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
        }
        .links a {
            color: #58a6ff;
            text-decoration: none;
        }
        .links a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    @await Html.PartialAsync("_Navbar")
    <div class="form-card">
        <a href="/" style="color:#2299dd;text-decoration:none;display:block;margin-bottom:20px;font-size:14px;">&#x1F3E0; &#x2190; 回首頁</a>
        <div class="form-title">📝 註冊帳號</div>
        <div class="form-subtitle">升級為正式會員，保存你的學習紀錄</div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post" action="/Account/Register" id="registerForm" onsubmit="return validateRegister()">
            <div class="form-group">
                <label>暱稱</label>
                <input type="text" name="nickname" placeholder="輸入你的暱稱" required maxlength="30" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
                <label>密碼</label>
                <input type="password" name="password" id="regPassword" required minlength="4" placeholder="至少 4 個字元" />
            </div>
            <div class="form-group">
                <label>確認密碼</label>
                <input type="password" name="confirmPassword" id="regConfirmPassword" required placeholder="再次輸入密碼" />
            </div>
            <div id="pwError" style="color:#f85149;font-size:13px;margin-bottom:8px;display:none;"></div>
            <button type="submit" class="btn-submit">註冊</button>
        </form>
        <script>
        function validateRegister() {
            var pw = document.getElementById('regPassword').value;
            var cpw = document.getElementById('regConfirmPassword').value;
            var errEl = document.getElementById('pwError');
            if (pw.length < 4) { errEl.textContent = '密碼至少需要 4 個字元'; errEl.style.display = 'block'; return false; }
            if (pw !== cpw) { errEl.textContent = '兩次輸入的密碼不一致'; errEl.style.display = 'block'; return false; }
            errEl.style.display = 'none';
            return true;
        }
        </script>

        <div class="links">
            已有帳號？<a href="/Account/Login">登入</a>
            &nbsp;|&nbsp;
            <a href="/">回首頁</a>
        </div>
    </div>
</body>
</html>
