@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>重設密碼 — .NET 學習平台</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background: #0d1117;
            color: #e6edf3;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 60px;
        }
        .form-card {
            background: linear-gradient(135deg, #161b22, #1c2333);
            border: 1px solid #30363d;
            border-radius: 16px;
            padding: 40px 32px;
            width: 100%;
            max-width: 420px;
            margin: 20px;
        }
        .form-title { font-size: 24px; font-weight: 800; text-align: center; margin-bottom: 8px; }
        .form-subtitle { font-size: 14px; color: #8b949e; text-align: center; margin-bottom: 28px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 13px; font-weight: 600; color: #8b949e; margin-bottom: 6px; }
        .form-group input {
            width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid #30363d;
            background: #0d1117; color: #e6edf3; font-size: 15px; font-family: 'Noto Sans TC', sans-serif;
            outline: none; transition: border-color 0.2s;
        }
        .form-group input:focus { border-color: #2299dd; }
        .btn-submit {
            width: 100%; padding: 12px; border-radius: 10px; border: none; background: #2299dd;
            color: #fff; font-size: 16px; font-weight: 700; cursor: pointer;
            font-family: 'Noto Sans TC', sans-serif; transition: background 0.2s; margin-top: 8px;
        }
        .btn-submit:hover { background: #1a7fc4; }
        .error-msg {
            background: rgba(248, 81, 73, 0.15); color: #f85149; border: 1px solid rgba(248, 81, 73, 0.3);
            border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px; text-align: center;
        }
        .password-hint { font-size: 12px; color: #8b949e; margin-top: 6px; }
        .links { text-align: center; margin-top: 20px; font-size: 14px; }
        .links a { color: #58a6ff; text-decoration: none; }
        .links a:hover { text-decoration: underline; }
        .pw-wrapper { position: relative; }
        .pw-wrapper input { padding-right: 40px; }
        .pw-toggle {
            position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
            background: none; border: none; font-size: 18px; cursor: pointer; color: #8b949e;
            padding: 4px;
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("_Navbar")
    <div class="form-card">
        <div class="form-title">重設密碼</div>
        <div class="form-subtitle">請輸入您的新密碼</div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post" action="/Account/ResetPassword">
            <input type="hidden" name="token" value="@ViewBag.Token" />
            <div class="form-group">
                <label>新密碼</label>
                <div class="pw-wrapper">
                    <input type="password" name="password" placeholder="輸入新密碼" required minlength="8" />
                    <button type="button" class="pw-toggle" onclick="togglePw(this)">&#x1F441;</button>
                </div>
                <div class="password-hint">至少 8 字元，需包含大寫、小寫字母和數字</div>
            </div>
            <div class="form-group">
                <label>確認新密碼</label>
                <div class="pw-wrapper">
                    <input type="password" name="passwordConfirm" placeholder="再次輸入新密碼" required minlength="8" />
                    <button type="button" class="pw-toggle" onclick="togglePw(this)">&#x1F441;</button>
                </div>
            </div>
            <button type="submit" class="btn-submit">重設密碼</button>
        </form>

        <div class="links">
            <a href="/Account/Login">返回登入</a>
        </div>
    </div>

    <script src="/js/site.js"></script>
    <script>
    function togglePw(btn) {
        var input = btn.parentElement.querySelector('input');
        if (input.type === 'password') {
            input.type = 'text';
            btn.textContent = '\u{1F648}';
        } else {
            input.type = 'password';
            btn.textContent = '\u{1F441}';
        }
    }
    </script>
</body>
</html>
