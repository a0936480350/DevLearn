@{
    ViewData["Title"] = "程式碼收藏";
}

<style>
    .snippet-page {
        max-width: 1100px;
        margin: 80px auto 40px;
        padding: 0 20px;
    }
    .snippet-hero {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .snippet-hero h1 {
        font-size: 1.8rem;
        color: var(--text-primary, #e0e0e0);
        margin: 0;
    }
    .snippet-hero p {
        color: var(--text-secondary, #aaa);
        margin: 4px 0 0;
        font-size: 0.95rem;
    }
    .btn-add-snippet {
        background: linear-gradient(135deg, #6c5ce7, #a855f7);
        color: #fff;
        border: none;
        padding: 10px 22px;
        border-radius: 10px;
        font-size: 0.95rem;
        cursor: pointer;
        font-weight: 600;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn-add-snippet:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(108, 92, 231, 0.4);
    }
    .snippet-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }
    .snippet-card {
        background: var(--card-bg, #1e1e2e);
        border: 1px solid var(--border, #2a2a3e);
        border-radius: 14px;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .snippet-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    .snippet-card-header {
        padding: 16px 18px 10px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
    .snippet-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text-primary, #e0e0e0);
        margin: 0;
    }
    .snippet-meta {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
        padding: 0 18px;
    }
    .lang-badge {
        background: rgba(108, 92, 231, 0.2);
        color: #a78bfa;
        padding: 2px 10px;
        border-radius: 6px;
        font-size: 0.78rem;
        font-weight: 600;
        font-family: 'JetBrains Mono', monospace;
    }
    .chapter-source {
        color: var(--text-secondary, #888);
        font-size: 0.8rem;
    }
    .snippet-code-preview {
        margin: 10px 18px;
        background: #0d1117;
        border-radius: 10px;
        overflow: hidden;
        max-height: 180px;
        overflow-y: auto;
    }
    .snippet-code-preview pre {
        margin: 0;
        padding: 14px;
        font-size: 0.82rem;
        line-height: 1.5;
    }
    .snippet-note {
        padding: 0 18px 6px;
        color: var(--text-secondary, #999);
        font-size: 0.85rem;
        font-style: italic;
    }
    .snippet-card-footer {
        padding: 10px 18px 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--border, #2a2a3e);
    }
    .snippet-date {
        color: var(--text-secondary, #666);
        font-size: 0.78rem;
    }
    .btn-delete-snippet {
        background: rgba(255, 71, 87, 0.15);
        color: #ff6b81;
        border: none;
        padding: 5px 14px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.82rem;
        transition: background 0.2s;
    }
    .btn-delete-snippet:hover {
        background: rgba(255, 71, 87, 0.3);
    }
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-secondary, #888);
    }
    .empty-state .empty-icon {
        font-size: 3rem;
        margin-bottom: 16px;
    }
    .empty-state p {
        font-size: 1.05rem;
    }
    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }
    .modal-overlay.active { display: flex; }
    .modal-box {
        background: var(--card-bg, #1e1e2e);
        border: 1px solid var(--border, #2a2a3e);
        border-radius: 16px;
        width: 90%;
        max-width: 560px;
        padding: 28px;
        max-height: 90vh;
        overflow-y: auto;
    }
    .modal-box h2 {
        margin: 0 0 20px;
        color: var(--text-primary, #e0e0e0);
        font-size: 1.3rem;
    }
    .form-group {
        margin-bottom: 16px;
    }
    .form-group label {
        display: block;
        color: var(--text-secondary, #aaa);
        font-size: 0.88rem;
        margin-bottom: 6px;
        font-weight: 500;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        background: var(--input-bg, #12121c);
        border: 1px solid var(--border, #2a2a3e);
        color: var(--text-primary, #e0e0e0);
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 0.92rem;
        box-sizing: border-box;
        font-family: inherit;
    }
    .form-group textarea {
        font-family: 'JetBrains Mono', monospace;
        min-height: 140px;
        resize: vertical;
    }
    .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 20px;
    }
    .btn-cancel {
        background: var(--border, #2a2a3e);
        color: var(--text-secondary, #aaa);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .btn-save {
        background: linear-gradient(135deg, #6c5ce7, #a855f7);
        color: #fff;
        border: none;
        padding: 10px 24px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 600;
    }
    .snippet-count {
        color: var(--text-secondary, #888);
        font-size: 0.9rem;
    }
</style>

<div class="snippet-page">
    <div class="snippet-hero">
        <div>
            <h1 data-i18n="snippet-title">📌 程式碼收藏</h1>
            <p data-i18n="snippet-desc">收藏實用的程式碼片段，隨時查閱</p>
        </div>
        <button class="btn-add-snippet" onclick="openAddModal()" data-i18n="snippet-add">＋ 新增片段</button>
    </div>

    <div class="snippet-count" id="snippetCount"></div>
    <div class="snippet-grid" id="snippetGrid"></div>
    <div class="empty-state" id="emptyState" style="display:none">
        <div class="empty-icon">📌</div>
        <p data-i18n="snippet-empty">還沒有收藏，在章節頁面點 📌 收藏程式碼</p>
    </div>
</div>

<!-- Add Modal -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <h2 data-i18n="snippet-create-title">📌 新增程式碼片段</h2>
        <div class="form-group">
            <label data-i18n="snippet-title-label">標題</label>
            <input type="text" id="snippetTitle" placeholder="例：LINQ GroupBy 範例" data-i18n-placeholder="snippet-title-ph" />
        </div>
        <div class="form-group">
            <label data-i18n="snippet-lang-label">程式語言</label>
            <select id="snippetLang">
                <option value="csharp">C#</option>
                <option value="sql">SQL</option>
                <option value="bash">Bash / CLI</option>
                <option value="yaml">YAML</option>
                <option value="docker">Dockerfile</option>
                <option value="json">JSON</option>
                <option value="xml">XML</option>
                <option value="html">HTML</option>
                <option value="css">CSS</option>
                <option value="javascript">JavaScript</option>
            </select>
        </div>
        <div class="form-group">
            <label data-i18n="snippet-code-label">程式碼</label>
            <textarea id="snippetCode" placeholder="貼上你的程式碼..." data-i18n-placeholder="snippet-code-ph"></textarea>
        </div>
        <div class="form-group">
            <label data-i18n="snippet-note-label">備註（選填）</label>
            <input type="text" id="snippetNote" placeholder="任何筆記或說明..." data-i18n-placeholder="snippet-note-ph" />
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeAddModal()" data-i18n="btn-cancel">取消</button>
            <button class="btn-save" onclick="saveSnippet()" data-i18n="btn-save">儲存</button>
        </div>
    </div>
</div>

<script>
    function loadSnippets() {
        fetch('/Snippet/MySnippets')
            .then(r => r.json())
            .then(data => {
                const grid = document.getElementById('snippetGrid');
                const empty = document.getElementById('emptyState');
                const countEl = document.getElementById('snippetCount');

                if (!data.length) {
                    grid.innerHTML = '';
                    empty.style.display = 'block';
                    countEl.textContent = '';
                    return;
                }

                empty.style.display = 'none';
                countEl.textContent = `${data.length} ${__t('snippet-count')}`;

                grid.innerHTML = data.map(s => {
                    const langMap = { csharp: 'C#', sql: 'SQL', bash: 'Bash', yaml: 'YAML', docker: 'Docker', json: 'JSON', xml: 'XML', html: 'HTML', css: 'CSS', javascript: 'JS' };
                    const langLabel = langMap[s.language] || s.language;
                    const escapedCode = escapeHtml(s.code);
                    const chapterHtml = s.chapterTitle ? `<span class="chapter-source">📖 ${escapeHtml(s.chapterTitle)}</span>` : '';
                    const noteHtml = s.note ? `<div class="snippet-note">💬 ${escapeHtml(s.note)}</div>` : '';
                    var langLocale = {zh:'zh-TW',en:'en-US',ja:'ja-JP'}[localStorage.getItem('lang')||'zh']||'zh-TW';
                    const dateStr = new Date(s.createdAt).toLocaleDateString(langLocale);

                    return `
                        <div class="snippet-card">
                            <div class="snippet-card-header">
                                <h3 class="snippet-title">${escapeHtml(s.title)}</h3>
                            </div>
                            <div class="snippet-meta">
                                <span class="lang-badge">${langLabel}</span>
                                ${chapterHtml}
                            </div>
                            <div class="snippet-code-preview">
                                <pre><code class="language-${s.language}">${escapedCode}</code></pre>
                            </div>
                            ${noteHtml}
                            <div class="snippet-card-footer">
                                <span class="snippet-date">${dateStr}</span>
                                <button class="btn-delete-snippet" onclick="deleteSnippet(${s.id})">${__t('snippet-delete')}</button>
                            </div>
                        </div>`;
                }).join('');

                // Re-highlight code
                if (window.Prism) Prism.highlightAll();
            });
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function openAddModal() {
        document.getElementById('addModal').classList.add('active');
    }

    function closeAddModal() {
        document.getElementById('addModal').classList.remove('active');
        document.getElementById('snippetTitle').value = '';
        document.getElementById('snippetCode').value = '';
        document.getElementById('snippetNote').value = '';
    }

    function saveSnippet() {
        const title = document.getElementById('snippetTitle').value.trim();
        const code = document.getElementById('snippetCode').value.trim();
        const language = document.getElementById('snippetLang').value;
        const note = document.getElementById('snippetNote').value.trim();

        if (!title || !code) {
            alert(__t('snippet-fill-required'));
            return;
        }

        fetch('/Snippet/Save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, code, language, note })
        })
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                closeAddModal();
                loadSnippets();
            }
        });
    }

    function deleteSnippet(id) {
        if (!confirm(__t('snippet-confirm-delete'))) return;
        fetch('/Snippet/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
        })
        .then(r => r.json())
        .then(data => {
            if (data.ok) loadSnippets();
        });
    }

    document.addEventListener('DOMContentLoaded', loadSnippets);

    // Close modal on overlay click
    document.getElementById('addModal').addEventListener('click', function(e) {
        if (e.target === this) closeAddModal();
    });
</script>
