@{
    Layout = null;
    var list = ViewBag.List as List<DotNetLearning.Models.Announcement> ?? new();
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>公告管理 — Admin</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Noto Sans TC',sans-serif;background:#0d1117;color:#e6edf3;min-height:100vh}
.topbar{background:#161b22;border-bottom:1px solid #30363d;padding:14px 24px;display:flex;align-items:center;gap:16px}
.topbar a{color:#58a6ff;text-decoration:none;font-size:0.9rem}
.topbar h1{font-size:1.1rem;font-weight:700}
.container{max-width:1100px;margin:30px auto;padding:0 20px}
.btn{padding:10px 20px;border-radius:8px;border:none;font-size:0.9rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s}
.btn-primary{background:linear-gradient(135deg,#3b82f6,#1d4ed8);color:#fff}
.btn-success{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff}
.btn-danger{background:rgba(239,68,68,.15);color:#ef4444;border:1px solid rgba(239,68,68,.3)}
.btn-sm{padding:6px 14px;font-size:0.82rem}
.card{background:#161b22;border:1px solid #30363d;border-radius:12px;padding:24px;margin-bottom:20px}
.card-title{font-size:1rem;font-weight:700;margin-bottom:16px;color:#e6edf3}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:0.82rem;color:#8b949e;margin-bottom:6px;font-weight:600}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:10px 14px;background:#0d1117;border:1px solid #30363d;border-radius:8px;color:#e6edf3;font-size:0.9rem;font-family:inherit;outline:none;transition:border-color .2s}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:#3b82f6}
.form-group textarea{height:90px;resize:vertical}
.form-row-3{display:flex;gap:16px;align-items:center;flex-wrap:wrap;margin-bottom:16px}
.checkbox-group{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.9rem}
.checkbox-group input{width:auto;accent-color:#3b82f6}
table{width:100%;border-collapse:collapse}
th{padding:10px 12px;text-align:left;font-size:0.82rem;color:#8b949e;border-bottom:1px solid #30363d}
td{padding:12px;border-bottom:1px solid #21262d;vertical-align:top}
.type-badge{border-radius:6px;padding:2px 10px;font-size:0.78rem;font-weight:600}
.type-info{background:rgba(59,130,246,.15);color:#3b82f6}
.type-success{background:rgba(34,197,94,.15);color:#22c55e}
.type-warning{background:rgba(245,158,11,.15);color:#f59e0b}
.type-danger{background:rgba(239,68,68,.15);color:#ef4444}
.badge-pin{background:rgba(239,68,68,.15);color:#ef4444;border-radius:4px;padding:1px 6px;font-size:0.72rem}
.badge-hidden{background:rgba(139,148,158,.15);color:#8b949e;border-radius:4px;padding:1px 6px;font-size:0.72rem}
.actions{display:flex;gap:8px;flex-wrap:wrap}
.msg{padding:10px 16px;border-radius:8px;margin-bottom:16px;display:none;font-size:0.9rem}
.msg.ok{background:rgba(34,197,94,.1);color:#22c55e;border:1px solid rgba(34,197,94,.3)}
.msg.err{background:rgba(239,68,68,.1);color:#ef4444;border:1px solid rgba(239,68,68,.3)}
.preview-box{border:1px solid #30363d;border-radius:8px;padding:12px 16px;background:#0d1117;margin-top:8px;min-height:40px;font-size:0.875rem;color:#c9d1d9;line-height:1.5}
</style>
</head>
<body>
<div class="topbar">
    <a href="/Admin/Dashboard">← 後台首頁</a>
    <h1>📢 公告管理</h1>
</div>
<div class="container">

    <div id="msg" class="msg"></div>

    <!-- 新增公告 -->
    <div class="card">
        <div class="card-title">➕ 新增公告</div>
        <div class="form-group">
            <label>標題</label>
            <input id="newTitle" type="text" placeholder="公告標題（可含 emoji）"/>
        </div>
        <div class="form-group">
            <label>內容</label>
            <textarea id="newContent" placeholder="公告內容..."></textarea>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>類型</label>
                <select id="newType">
                    <option value="info">📢 資訊 (藍)</option>
                    <option value="success">✅ 成功 (綠)</option>
                    <option value="warning">⚠️ 警告 (黃)</option>
                    <option value="danger">🚨 緊急 (紅)</option>
                </select>
            </div>
            <div class="form-group">
                <label>到期日（選填，留空 = 永久）</label>
                <input id="newExpires" type="datetime-local"/>
            </div>
        </div>
        <div class="form-row-3">
            <label class="checkbox-group"><input type="checkbox" id="newPinned"> 📌 置頂</label>
            <label class="checkbox-group"><input type="checkbox" id="newVisible" checked> 👁️ 立即顯示</label>
        </div>
        <button class="btn btn-primary" onclick="createAnn()">➕ 新增公告</button>
    </div>

    <!-- 公告列表 -->
    <div class="card">
        <div class="card-title">📋 公告列表（共 @list.Count 筆）</div>
        @if (!list.Any())
        {
            <div style="color:#8b949e;text-align:center;padding:30px">還沒有公告</div>
        }
        else
        {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>標題 / 內容</th>
                    <th>類型</th>
                    <th>日期</th>
                    <th>狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ann in list)
            {
                <tr id="row-@ann.Id">
                    <td style="color:#8b949e;font-size:0.85rem">#@ann.Id</td>
                    <td>
                        <div style="font-weight:700;margin-bottom:4px">
                            @if (ann.IsPinned) { <span class="badge-pin">📌 置頂</span> }
                            @ann.Title
                        </div>
                        <div style="color:#8b949e;font-size:0.82rem;max-width:400px">@(ann.Content.Length > 80 ? ann.Content[..80] + "..." : ann.Content)</div>
                    </td>
                    <td><span class="type-badge type-@ann.Type">@ann.Type</span></td>
                    <td style="font-size:0.82rem;white-space:nowrap">
                        <div>@ann.CreatedAt.ToString("yyyy/MM/dd")</div>
                        <div style="color:#8b949e">@ann.CreatedAt.ToString("HH:mm")</div>
                        @if (ann.ExpiresAt.HasValue) {
                            <div style="color:#f59e0b;font-size:0.78rem">到期：@ann.ExpiresAt.Value.ToString("yyyy/MM/dd")</div>
                        }
                    </td>
                    <td>
                        @if (ann.IsVisible) {
                            <span style="color:#22c55e;font-size:0.82rem">● 顯示中</span>
                        } else {
                            <span class="badge-hidden">隱藏</span>
                        }
                    </td>
                    <td>
                        <div class="actions">
                            <button class="btn btn-sm" style="background:#21262d;border:1px solid #30363d;color:#e6edf3" onclick="editAnn(@ann.Id,'@Html.Raw(ann.Title.Replace("'","\\'")))','@Html.Raw(ann.Content.Replace("'","\\'").Replace("\n","\\n"))','@ann.Type',@ann.IsPinned.ToString().ToLower(),@ann.IsVisible.ToString().ToLower())">✏️ 編輯</button>
                            <button class="btn btn-sm" style="background:#21262d;border:1px solid #30363d;color:#e6edf3" onclick="toggleAnn(@ann.Id)">@(ann.IsVisible ? "🙈 隱藏" : "👁️ 顯示")</button>
                            <button class="btn btn-sm btn-danger" onclick="deleteAnn(@ann.Id)">🗑️ 刪除</button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        }
    </div>
</div>

<!-- 編輯 Modal -->
<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;align-items:center;justify-content:center">
    <div style="background:#161b22;border:1px solid #30363d;border-radius:16px;padding:32px;width:90%;max-width:560px">
        <div style="font-size:1.1rem;font-weight:700;margin-bottom:20px">✏️ 編輯公告</div>
        <input type="hidden" id="editId"/>
        <div class="form-group"><label>標題</label><input id="editTitle" type="text"/></div>
        <div class="form-group"><label>內容</label><textarea id="editContent"></textarea></div>
        <div class="form-row">
            <div class="form-group"><label>類型</label>
                <select id="editType">
                    <option value="info">📢 資訊</option>
                    <option value="success">✅ 成功</option>
                    <option value="warning">⚠️ 警告</option>
                    <option value="danger">🚨 緊急</option>
                </select>
            </div>
            <div class="form-group"><label>到期日</label><input id="editExpires" type="datetime-local"/></div>
        </div>
        <div class="form-row-3">
            <label class="checkbox-group"><input type="checkbox" id="editPinned"> 📌 置頂</label>
            <label class="checkbox-group"><input type="checkbox" id="editVisible"> 👁️ 顯示</label>
        </div>
        <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:8px">
            <button class="btn" style="background:#21262d;border:1px solid #30363d;color:#e6edf3" onclick="closeEdit()">取消</button>
            <button class="btn btn-primary" onclick="saveEdit()">💾 儲存</button>
        </div>
    </div>
</div>

<script>
function showMsg(text, ok) {
    var el = document.getElementById('msg');
    el.textContent = text;
    el.className = 'msg ' + (ok ? 'ok' : 'err');
    el.style.display = 'block';
    setTimeout(()=>el.style.display='none', 3000);
}

async function createAnn() {
    var title = document.getElementById('newTitle').value.trim();
    var content = document.getElementById('newContent').value.trim();
    if (!title || !content) { showMsg('請填寫標題和內容', false); return; }
    var expires = document.getElementById('newExpires').value;
    var res = await fetch('/Admin/AnnouncementCreate', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
            id: 0, title, content,
            type: document.getElementById('newType').value,
            isPinned: document.getElementById('newPinned').checked,
            isVisible: document.getElementById('newVisible').checked,
            expiresAt: expires || null
        })
    });
    if (res.ok) { showMsg('✅ 公告已新增', true); setTimeout(()=>location.reload(), 1000); }
    else showMsg('❌ 新增失敗', false);
}

function editAnn(id, title, content, type, pinned, visible) {
    document.getElementById('editId').value = id;
    document.getElementById('editTitle').value = title;
    document.getElementById('editContent').value = content;
    document.getElementById('editType').value = type;
    document.getElementById('editPinned').checked = pinned;
    document.getElementById('editVisible').checked = visible;
    document.getElementById('editModal').style.display = 'flex';
}

function closeEdit() { document.getElementById('editModal').style.display = 'none'; }

async function saveEdit() {
    var expires = document.getElementById('editExpires').value;
    var res = await fetch('/Admin/AnnouncementUpdate', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
            id: parseInt(document.getElementById('editId').value),
            title: document.getElementById('editTitle').value,
            content: document.getElementById('editContent').value,
            type: document.getElementById('editType').value,
            isPinned: document.getElementById('editPinned').checked,
            isVisible: document.getElementById('editVisible').checked,
            expiresAt: expires || null
        })
    });
    if (res.ok) { showMsg('✅ 已更新', true); closeEdit(); setTimeout(()=>location.reload(), 800); }
    else showMsg('❌ 更新失敗', false);
}

async function toggleAnn(id) {
    var res = await fetch('/Admin/AnnouncementToggle', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({id})
    });
    if (res.ok) { showMsg('✅ 已切換', true); setTimeout(()=>location.reload(), 600); }
}

async function deleteAnn(id) {
    if (!confirm('確定要刪除這則公告嗎？')) return;
    var res = await fetch('/Admin/AnnouncementDelete', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({id})
    });
    if (res.ok) { document.getElementById('row-'+id)?.remove(); showMsg('✅ 已刪除', true); }
    else showMsg('❌ 刪除失敗', false);
}
</script>
</body>
</html>
