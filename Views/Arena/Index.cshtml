@{
    ViewData["Title"] = "程式碼擂台";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />

<style>
    .arena-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 20px;
        color: #e0e0e0;
    }

    .arena-header {
        text-align: center;
        margin-bottom: 40px;
        padding: 30px 0;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        border-radius: 16px;
        border: 1px solid #e94560;
        box-shadow: 0 0 30px rgba(233, 69, 96, 0.2);
    }

    .arena-header h1 {
        font-size: 2.5rem;
        margin: 0;
        background: linear-gradient(90deg, #e94560, #ff6b6b, #ffd93d);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: none;
    }

    .arena-header p {
        color: #aaa;
        font-size: 1.1rem;
        margin-top: 8px;
    }

    .challenges-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .challenge-card {
        background: #1a1a2e;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 24px;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .challenge-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #e94560, #ffd93d);
        opacity: 0;
        transition: opacity 0.3s;
    }

    .challenge-card:hover {
        border-color: #e94560;
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(233, 69, 96, 0.15);
    }

    .challenge-card:hover::before {
        opacity: 1;
    }

    .challenge-card h3 {
        color: #fff;
        margin: 0 0 10px 0;
        font-size: 1.2rem;
    }

    .challenge-card .description {
        color: #999;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 15px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .challenge-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

    .difficulty-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .difficulty-beginner { background: #1b4332; color: #52b788; }
    .difficulty-intermediate { background: #3a2d00; color: #ffd93d; }
    .difficulty-advanced { background: #3d0000; color: #ff6b6b; }

    .submission-count {
        color: #888;
        font-size: 0.85rem;
    }

    .countdown {
        color: #e94560;
        font-size: 0.8rem;
        font-weight: bold;
    }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.85);
        z-index: 1000;
        overflow-y: auto;
        padding: 30px 15px;
    }

    .modal-overlay.active { display: flex; justify-content: center; align-items: flex-start; }

    .modal-content {
        background: #16213e;
        border: 1px solid #e94560;
        border-radius: 16px;
        width: 100%;
        max-width: 900px;
        padding: 30px;
        position: relative;
        box-shadow: 0 0 50px rgba(233, 69, 96, 0.2);
    }

    .modal-close {
        position: absolute;
        top: 15px; right: 20px;
        background: none; border: none;
        color: #888; font-size: 1.8rem;
        cursor: pointer;
        transition: color 0.2s;
    }

    .modal-close:hover { color: #e94560; }

    .modal-content h2 {
        color: #fff;
        margin: 0 0 8px 0;
    }

    .modal-description {
        color: #bbb;
        line-height: 1.7;
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #333;
    }

    /* Form */
    .submit-section {
        background: #1a1a2e;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #333;
    }

    .submit-section h3 {
        color: #ffd93d;
        margin: 0 0 16px 0;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        color: #ccc;
        margin-bottom: 6px;
        font-size: 0.9rem;
    }

    .form-group textarea,
    .form-group input,
    .form-group select {
        width: 100%;
        padding: 10px 14px;
        background: #0f0f23;
        border: 1px solid #444;
        border-radius: 8px;
        color: #e0e0e0;
        font-size: 0.95rem;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    .form-group textarea:focus,
    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #e94560;
    }

    .form-group textarea.code-input {
        font-family: 'Consolas', 'Fira Code', 'Source Code Pro', monospace;
        min-height: 150px;
        line-height: 1.5;
        tab-size: 4;
        resize: vertical;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #e94560, #c7254e);
        color: #fff;
        border: none;
        padding: 12px 32px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(233, 69, 96, 0.4);
    }

    .btn-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    /* Submissions */
    .submissions-section h3 {
        color: #fff;
        margin-bottom: 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid #333;
    }

    .submission-card {
        background: #1a1a2e;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        transition: border-color 0.2s;
    }

    .submission-card:hover { border-color: #555; }

    .submission-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .submission-rank {
        font-size: 1.4rem;
        margin-right: 10px;
    }

    .submission-nickname {
        color: #fff;
        font-weight: bold;
        font-size: 1.05rem;
    }

    .submission-time {
        color: #666;
        font-size: 0.8rem;
    }

    .submission-code {
        background: #0f0f23;
        border-radius: 8px;
        padding: 16px;
        margin: 12px 0;
        overflow-x: auto;
        border: 1px solid #2a2a4a;
    }

    .submission-code pre {
        margin: 0;
        font-size: 0.85rem;
        line-height: 1.5;
    }

    .submission-code code {
        font-family: 'Consolas', 'Fira Code', 'Source Code Pro', monospace;
    }

    .submission-explanation {
        color: #aaa;
        font-size: 0.9rem;
        line-height: 1.5;
        padding: 10px 0;
        font-style: italic;
    }

    .upvote-btn {
        background: #1a1a2e;
        border: 1px solid #444;
        border-radius: 20px;
        padding: 6px 16px;
        color: #e94560;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .upvote-btn:hover {
        background: #e94560;
        color: #fff;
        border-color: #e94560;
    }

    .upvote-btn.voted {
        background: #e94560;
        color: #fff;
        border-color: #e94560;
    }

    .no-submissions {
        text-align: center;
        color: #666;
        padding: 40px;
        font-size: 1rem;
    }

    .toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        padding: 14px 24px;
        border-radius: 10px;
        color: #fff;
        font-weight: bold;
        z-index: 2000;
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s ease;
    }

    .toast.show {
        transform: translateY(0);
        opacity: 1;
    }

    .toast.success { background: #1b4332; border: 1px solid #52b788; }
    .toast.error { background: #3d0000; border: 1px solid #ff6b6b; }

    .loading-spinner {
        text-align: center;
        padding: 40px;
        color: #888;
    }
</style>

<div class="arena-container">
    <div class="arena-header">
        <h1 data-i18n="game-arena">⚔️ 程式碼擂台</h1>
        <p>比誰的解法更優雅</p>
    </div>

    <div id="challenges-loading" class="loading-spinner">載入挑戰中...</div>
    <div id="challenges-grid" class="challenges-grid"></div>
</div>

<!-- Detail Modal -->
<div id="detail-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal()">&times;</button>
        <div id="modal-body"></div>
    </div>
</div>

<div id="toast" class="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-csharp.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-java.min.js"></script>

<script>
    const votedSet = new Set(JSON.parse(localStorage.getItem('arena_voted') || '[]'));

    function saveVoted() {
        localStorage.setItem('arena_voted', JSON.stringify([...votedSet]));
    }

    function showToast(msg, type = 'success') {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.className = 'toast ' + type;
        setTimeout(() => t.classList.add('show'), 10);
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    function getDifficultyLabel(d) {
        const map = { beginner: '入門', intermediate: '中階', advanced: '進階' };
        return map[d] || d;
    }

    function getCountdown(endDate) {
        const diff = new Date(endDate) - new Date();
        if (diff <= 0) return '已結束';
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        return `剩餘 ${days} 天 ${hours} 小時`;
    }

    function getRankMedal(i) {
        if (i === 0) return '🥇';
        if (i === 1) return '🥈';
        if (i === 2) return '🥉';
        return `#${i + 1}`;
    }

    function getPrismLang(lang) {
        const map = { csharp: 'csharp', javascript: 'javascript', python: 'python', java: 'java' };
        return map[lang] || 'csharp';
    }

    function escapeHtml(text) {
        const d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    // Load challenges
    async function loadChallenges() {
        try {
            const res = await fetch('/Arena/Challenges');
            const data = await res.json();
            const grid = document.getElementById('challenges-grid');
            document.getElementById('challenges-loading').style.display = 'none';

            if (!data.length) {
                grid.innerHTML = '<p style="color:#888;text-align:center;grid-column:1/-1">目前沒有進行中的挑戰</p>';
                return;
            }

            grid.innerHTML = data.map(c => `
                <div class="challenge-card" onclick="openChallenge(${c.id})">
                    <h3>${escapeHtml(c.title)}</h3>
                    <div class="description">${escapeHtml(c.description)}</div>
                    <div class="challenge-meta">
                        <span class="difficulty-badge difficulty-${c.difficulty}">${getDifficultyLabel(c.difficulty)}</span>
                        <span class="submission-count">📝 ${c.submissionCount} 份提交</span>
                        <span class="countdown">⏰ ${getCountdown(c.endDate)}</span>
                    </div>
                </div>
            `).join('');
        } catch (e) {
            document.getElementById('challenges-loading').textContent = '載入失敗，請重新整理頁面';
        }
    }

    // Open challenge detail
    async function openChallenge(id) {
        const modal = document.getElementById('detail-modal');
        const body = document.getElementById('modal-body');
        modal.classList.add('active');
        body.innerHTML = '<div class="loading-spinner">載入中...</div>';

        try {
            const res = await fetch(`/Arena/Detail?id=${id}`);
            const data = await res.json();
            const c = data.challenge;
            const subs = data.submissions;

            body.innerHTML = `
                <h2>${escapeHtml(c.title)}</h2>
                <span class="difficulty-badge difficulty-${c.difficulty}" style="margin-bottom:12px;display:inline-block">${getDifficultyLabel(c.difficulty)}</span>
                <div class="modal-description">${escapeHtml(c.description)}</div>

                <div class="submit-section">
                    <h3>📮 提交解法</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>暱稱</label>
                            <input type="text" id="sub-nickname" placeholder="你的暱稱" maxlength="30" />
                        </div>
                        <div class="form-group">
                            <label>語言</label>
                            <select id="sub-language">
                                <option value="csharp">C#</option>
                                <option value="javascript">JavaScript</option>
                                <option value="python">Python</option>
                                <option value="java">Java</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>程式碼</label>
                        <textarea class="code-input" id="sub-code" placeholder="貼上你的程式碼..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>解題思路</label>
                        <textarea id="sub-explanation" rows="3" placeholder="簡單說明你的解法思路..."></textarea>
                    </div>
                    <button class="btn-submit" id="btn-submit" onclick="submitSolution(${c.id})">⚔️ 提交解法</button>
                </div>

                <div class="submissions-section">
                    <h3>🏆 排行榜 (${subs.length} 份提交)</h3>
                    ${subs.length === 0 ? '<div class="no-submissions">還沒有人提交，成為第一個挑戰者吧！</div>' :
                    subs.map((s, i) => `
                        <div class="submission-card">
                            <div class="submission-header">
                                <div>
                                    <span class="submission-rank">${getRankMedal(i)}</span>
                                    <span class="submission-nickname">${escapeHtml(s.nickname)}</span>
                                </div>
                                <div style="display:flex;align-items:center;gap:12px">
                                    <button class="upvote-btn ${votedSet.has(s.id) ? 'voted' : ''}" onclick="upvote(${s.id}, this)" ${votedSet.has(s.id) ? 'disabled' : ''}>
                                        👍 <span>${s.upvotes}</span>
                                    </button>
                                    <span class="submission-time">${new Date(s.submittedAt).toLocaleString('zh-TW')}</span>
                                </div>
                            </div>
                            <div class="submission-code">
                                <pre><code class="language-${getPrismLang(s.language)}">${escapeHtml(s.code)}</code></pre>
                            </div>
                            ${s.explanation ? `<div class="submission-explanation">💡 ${escapeHtml(s.explanation)}</div>` : ''}
                        </div>
                    `).join('')}
                </div>
            `;

            Prism.highlightAll();
        } catch (e) {
            body.innerHTML = '<p style="color:#ff6b6b">載入失敗</p>';
        }
    }

    async function submitSolution(challengeId) {
        const btn = document.getElementById('btn-submit');
        const code = document.getElementById('sub-code').value.trim();
        if (!code) { showToast('請輸入程式碼', 'error'); return; }

        btn.disabled = true;
        btn.textContent = '提交中...';

        try {
            const res = await fetch('/Arena/Submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    arenaChallengeId: challengeId,
                    nickname: document.getElementById('sub-nickname').value,
                    code: code,
                    language: document.getElementById('sub-language').value,
                    explanation: document.getElementById('sub-explanation').value
                })
            });
            const data = await res.json();
            if (data.success) {
                showToast('提交成功！');
                openChallenge(challengeId);
            } else {
                showToast(data.error || '提交失敗', 'error');
            }
        } catch (e) {
            showToast('網路錯誤', 'error');
        } finally {
            btn.disabled = false;
            btn.textContent = '⚔️ 提交解法';
        }
    }

    async function upvote(submissionId, btn) {
        if (votedSet.has(submissionId)) return;

        try {
            const res = await fetch('/Arena/Upvote', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ submissionId })
            });
            const data = await res.json();
            if (data.success) {
                btn.querySelector('span').textContent = data.upvotes;
                btn.classList.add('voted');
                btn.disabled = true;
                votedSet.add(submissionId);
                saveVoted();
                showToast('已投票！');
            }
        } catch (e) {
            showToast('投票失敗', 'error');
        }
    }

    function closeModal() {
        document.getElementById('detail-modal').classList.remove('active');
    }

    document.getElementById('detail-modal').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    loadChallenges();
</script>
