@{
    ViewData["Title"] = "上傳檔案";
}

<style>
    .up-wrap { max-width: 700px; margin: 0 auto; padding: 30px 20px; }
    .up-title { font-size: 28px; font-weight: 800; color: #e6edf3; margin-bottom: 20px; }
    .up-form {
        background: #161b22; border: 1px solid #30363d; border-radius: 12px;
        padding: 30px;
    }
    .up-field { margin-bottom: 20px; }
    .up-label { display: block; color: #c9d1d9; font-weight: 600; margin-bottom: 6px; font-size: 14px; }
    .up-hint { color: #6e7681; font-size: 12px; margin-top: 4px; }
    .up-input, .up-select, .up-textarea {
        width: 100%; padding: 10px 14px; background: #0d1117; border: 1px solid #30363d;
        color: #e6edf3; border-radius: 8px; font-size: 14px; box-sizing: border-box;
    }
    .up-input:focus, .up-select:focus, .up-textarea:focus { border-color: #58a6ff; outline: none; }
    .up-textarea { min-height: 80px; resize: vertical; font-family: inherit; }
    .up-file {
        border: 2px dashed #30363d; padding: 30px; text-align: center;
        border-radius: 8px; cursor: pointer; transition: all 0.2s;
    }
    .up-file:hover { border-color: #58a6ff; background: #0d1117; }
    .up-file input { display: none; }
    .up-buttons { display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px; }
    .up-btn {
        padding: 10px 24px; border-radius: 8px; font-weight: 600;
        text-decoration: none; cursor: pointer; border: none; font-size: 14px;
    }
    .up-btn-cancel { background: #21262d; color: #c9d1d9; }
    .up-btn-submit { background: linear-gradient(135deg, #238636, #2ea043); color: white; }
    .up-alert {
        padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-weight: 500;
        background: #2d0f0f; color: #f85149; border: 1px solid #da3633;
    }
</style>

<div class="up-wrap">
    <h1 class="up-title">📤 上傳新檔案</h1>

    @if (TempData["Error"] != null)
    {
        <div class="up-alert">❌ @TempData["Error"]</div>
    }

    <form method="post" enctype="multipart/form-data" class="up-form">
        <div class="up-field">
            <label class="up-label">選擇檔案 *</label>
            <label class="up-file">
                <input type="file" name="file" id="fileInput" required onchange="updateFileName(this)">
                <div id="fileDisplay" style="color: #8b949e;">
                    📎 點擊選擇檔案（PDF / Word / PPT / 圖片 / ZIP...）
                </div>
            </label>
            <div class="up-hint">支援：pdf、docx、pptx、xlsx、png/jpg/gif/webp、txt、md、zip、7z（最大 50 MB）</div>
        </div>

        <div class="up-field">
            <label class="up-label">標題 *</label>
            <input type="text" name="title" class="up-input" placeholder="例如：GitHub CI/CD 流程筆記" required>
        </div>

        <div class="up-field">
            <label class="up-label">分類</label>
            <select name="category" class="up-select">
                <option value="general">📁 一般</option>
                <option value="tutorial">📖 教學</option>
                <option value="notes" selected>📝 筆記</option>
                <option value="slides">🎨 投影片</option>
            </select>
        </div>

        <div class="up-field">
            <label class="up-label">描述</label>
            <textarea name="description" class="up-textarea" placeholder="簡短介紹這個檔案的內容..."></textarea>
        </div>

        <div class="up-field">
            <label class="up-label">標籤</label>
            <input type="text" name="tags" class="up-input" placeholder="用逗號分隔，例如：Git,CI/CD,面試">
            <div class="up-hint">多個標籤用逗號分隔</div>
        </div>

        <div class="up-buttons">
            <a href="/SharedFile" class="up-btn up-btn-cancel">取消</a>
            <button type="submit" class="up-btn up-btn-submit">📤 上傳</button>
        </div>
    </form>
</div>

<script>
function updateFileName(input) {
    const d = document.getElementById('fileDisplay');
    if (input.files && input.files[0]) {
        const f = input.files[0];
        const size = f.size < 1024 * 1024 ? (f.size / 1024).toFixed(1) + ' KB' : (f.size / 1024 / 1024).toFixed(1) + ' MB';
        d.innerHTML = `✅ <strong style="color:#3fb950">${f.name}</strong> <span style="color:#6e7681">(${size})</span>`;
    }
}
</script>
