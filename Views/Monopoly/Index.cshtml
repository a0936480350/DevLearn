@{
    ViewData["Title"] = "程式碼大富翁";
}

<style>
    /* === Code Monopoly 2D Board Theme === */
    .monopoly-container {
        max-width: 100vw;
        margin: 0 auto;
        padding: 10px;
        font-family: 'Segoe UI', sans-serif;
        color: #e0e0e0;
        user-select: none;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: calc(100vh - 80px);
    }

    /* === 2D Board Grid === */
    .board-2d {
        display: grid;
        grid-template-columns: repeat(7, 80px);
        grid-template-rows: repeat(7, 80px);
        gap: 3px;
        position: relative;
    }

    /* Center area spans 5x5 */
    .center-area {
        grid-column: 2 / 7;
        grid-row: 2 / 7;
        background: linear-gradient(145deg, #0d1117, #161b22);
        border: 2px solid #30363d;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 16px;
        gap: 10px;
        position: relative;
        overflow: hidden;
        z-index: 1;
    }
    .center-area::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(99,102,241,0.06) 0%, transparent 70%);
        pointer-events: none;
    }

    .center-title {
        font-size: 1.6rem;
        font-weight: 900;
        background: linear-gradient(135deg, #f59e0b, #ef4444, #a855f7, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-align: center;
        line-height: 1.2;
    }
    .center-subtitle {
        color: #6e7681;
        font-size: 0.75rem;
        text-align: center;
    }

    /* Dice area in center */
    .dice-area {
        display: flex;
        align-items: center;
        gap: 14px;
        margin: 4px 0;
    }
    .dice-face {
        font-size: 3rem;
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0d1117;
        border: 2px solid #30363d;
        border-radius: 14px;
        transition: transform 0.3s;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.4), 0 4px 12px rgba(0,0,0,0.3);
    }
    .dice-rolling {
        animation: diceRoll 0.1s linear infinite;
    }
    @@keyframes diceRoll {
        0% { transform: rotate(0deg) scale(1); }
        25% { transform: rotate(90deg) scale(1.15); }
        50% { transform: rotate(180deg) scale(1); }
        75% { transform: rotate(270deg) scale(1.15); }
        100% { transform: rotate(360deg) scale(1); }
    }

    .dice-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        border: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
        position: relative;
        overflow: hidden;
    }
    .dice-btn:hover:not(:disabled) {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 6px 25px rgba(99, 102, 241, 0.6);
    }
    .dice-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        animation: none;
    }
    .dice-btn.pulsing {
        animation: btnPulse 1.8s ease-in-out infinite;
    }
    @@keyframes btnPulse {
        0%, 100% { box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4); }
        50% { box-shadow: 0 4px 30px rgba(99, 102, 241, 0.8), 0 0 60px rgba(139, 92, 246, 0.3); }
    }

    /* Stats in center */
    .center-stats {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
    }
    .stat-badge {
        display: flex;
        align-items: center;
        gap: 5px;
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 5px 10px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .hp-hearts { color: #ef4444; font-size: 1.15rem; letter-spacing: 1px; }
    .hp-hearts .heart-lost { opacity: 0.2; }
    .coins-value { color: #f59e0b; font-size: 1.1rem; font-weight: 800; }

    /* Message log in center */
    .center-log {
        width: 100%;
        background: #0d1117;
        border: 1px solid #21262d;
        border-radius: 8px;
        padding: 6px 10px;
        max-height: 70px;
        overflow-y: auto;
        font-size: 0.72rem;
        color: #8b949e;
        line-height: 1.5;
    }
    .center-log .msg-item { padding: 1px 0; }

    /* === Board Squares === */
    .board-square {
        width: 80px;
        height: 80px;
        background: #161b22;
        border: 2px solid #30363d;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        transition: all 0.3s ease;
        position: relative;
        cursor: default;
        overflow: hidden;
        box-sizing: border-box;
    }
    .board-square::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        border-radius: 6px 6px 0 0;
    }
    .board-square .sq-icon {
        font-size: 1.3rem;
        margin-bottom: 2px;
        line-height: 1;
    }
    .board-square .sq-title {
        font-size: 0.6rem;
        font-weight: 700;
        line-height: 1.15;
        max-height: 2.3em;
        overflow: hidden;
        padding: 0 2px;
        color: #c9d1d9;
    }
    .board-square .sq-id {
        font-size: 0.5rem;
        color: #484f58;
        position: absolute;
        bottom: 2px;
        right: 4px;
    }

    /* Square type colors - gradient top border */
    .sq-question::before { background: linear-gradient(90deg, #2563eb, #60a5fa); }
    .sq-question { border-color: #3b82f6; }

    .sq-bonus::before { background: linear-gradient(90deg, #d97706, #fbbf24); }
    .sq-bonus { border-color: #f59e0b; }

    .sq-trap::before { background: linear-gradient(90deg, #dc2626, #f87171); }
    .sq-trap { border-color: #ef4444; }

    .sq-heal::before { background: linear-gradient(90deg, #16a34a, #4ade80); }
    .sq-heal { border-color: #22c55e; }

    .sq-skip::before { background: linear-gradient(90deg, #9333ea, #c084fc); }
    .sq-skip { border-color: #a855f7; }

    .sq-start::before { background: linear-gradient(90deg, #16a34a, #fbbf24, #16a34a); }
    .sq-start { border-color: #22c55e; background: linear-gradient(135deg, #0d1117, #132218); }

    .sq-finish::before { background: linear-gradient(90deg, #f59e0b, #ef4444, #a855f7); }
    .sq-finish { border-color: #f59e0b; background: linear-gradient(135deg, #1f1507, #1a0f0f); }

    /* Current square glow + pulse */
    .sq-current {
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.7), 0 0 35px rgba(99, 102, 241, 0.25);
        border-color: #818cf8 !important;
        z-index: 5;
        animation: currentPulse 2s ease-in-out infinite;
    }
    @@keyframes currentPulse {
        0%, 100% { box-shadow: 0 0 15px rgba(99, 102, 241, 0.7), 0 0 35px rgba(99, 102, 241, 0.25); }
        50% { box-shadow: 0 0 25px rgba(99, 102, 241, 0.9), 0 0 50px rgba(99, 102, 241, 0.4); }
    }

    /* Visited squares */
    .sq-visited {
        opacity: 0.5;
        filter: saturate(0.5);
    }

    /* Player token */
    .player-token {
        position: absolute;
        top: -6px;
        right: -2px;
        font-size: 1.2rem;
        animation: tokenBounce 1.2s ease-in-out infinite;
        z-index: 10;
        filter: drop-shadow(0 2px 6px rgba(0,0,0,0.7));
    }
    @@keyframes tokenBounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

    /* === Question Modal === */
    .question-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.88);
        z-index: 100;
        justify-content: center;
        align-items: center;
    }
    .question-overlay.active { display: flex; }
    .question-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 16px;
        padding: 28px;
        max-width: 500px;
        width: 90%;
        animation: popIn 0.4s ease;
    }
    @@keyframes popIn {
        0% { transform: scale(0.8); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
    .question-card h3 {
        color: #58a6ff;
        margin-bottom: 6px;
        font-size: 1rem;
    }
    .question-text {
        color: #e6edf3;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 16px;
        line-height: 1.5;
    }
    .timer-bar-wrap {
        background: #21262d;
        border-radius: 6px;
        height: 8px;
        margin-bottom: 12px;
        overflow: hidden;
    }
    .timer-bar {
        height: 100%;
        background: linear-gradient(90deg, #22c55e, #f59e0b, #ef4444);
        border-radius: 6px;
        transition: width 0.1s linear;
        width: 100%;
    }
    .timer-text {
        text-align: center;
        font-size: 0.8rem;
        color: #8b949e;
        margin-bottom: 10px;
    }
    .options-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .option-btn {
        background: #0d1117;
        border: 2px solid #30363d;
        border-radius: 10px;
        padding: 11px 14px;
        color: #e6edf3;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }
    .option-btn:hover:not(:disabled) {
        border-color: #58a6ff;
        background: #1a2332;
    }
    .option-btn.correct {
        border-color: #22c55e;
        background: rgba(34, 197, 94, 0.15);
        color: #4ade80;
    }
    .option-btn.wrong {
        border-color: #ef4444;
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
    }
    .option-btn:disabled { cursor: not-allowed; }
    .coins-reward {
        font-size: 0.8rem;
        color: #f59e0b;
        margin-top: 4px;
    }

    /* === Event Popup === */
    .event-popup {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.88);
        z-index: 100;
        justify-content: center;
        align-items: center;
    }
    .event-popup.active { display: flex; }
    .event-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 16px;
        padding: 36px;
        text-align: center;
        max-width: 380px;
        width: 90%;
        animation: popIn 0.4s ease;
    }
    .event-card .event-icon { font-size: 3.2rem; margin-bottom: 10px; }
    .event-card .event-title { font-size: 1.3rem; font-weight: 700; color: #e6edf3; margin-bottom: 6px; }
    .event-card .event-desc { color: #8b949e; font-size: 0.95rem; margin-bottom: 18px; }
    .event-ok-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        border: none;
        padding: 10px 28px;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.15s;
    }
    .event-ok-btn:hover { transform: scale(1.04); }

    /* === Game Over Overlay === */
    .gameover-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.92);
        z-index: 200;
        justify-content: center;
        align-items: center;
    }
    .gameover-overlay.active { display: flex; }
    .gameover-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 16px;
        padding: 36px;
        text-align: center;
        max-width: 460px;
        width: 90%;
        animation: popIn 0.5s ease;
    }
    .gameover-card h2 { font-size: 1.8rem; margin-bottom: 6px; color: #e6edf3; }
    .gameover-card .result-emoji { font-size: 2.8rem; margin-bottom: 10px; }
    .stat-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin: 16px 0;
    }
    .stat-item {
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 10px;
        padding: 12px;
    }
    .stat-item .stat-value { font-size: 1.4rem; font-weight: 800; color: #58a6ff; }
    .stat-item .stat-label { font-size: 0.75rem; color: #8b949e; margin-top: 2px; }
    .gameover-btns {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-top: 16px;
    }
    .btn-primary {
        padding: 10px 24px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.15s;
    }
    .btn-primary:hover { transform: scale(1.04); }
    .btn-secondary {
        padding: 10px 24px;
        background: #21262d;
        color: #8b949e;
        border: 1px solid #30363d;
        border-radius: 10px;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-secondary:hover { border-color: #58a6ff; color: #58a6ff; }

    /* === Floating Effects === */
    .float-coin {
        position: fixed;
        font-size: 1.5rem;
        pointer-events: none;
        z-index: 300;
        animation: floatUp 1.2s ease-out forwards;
    }
    @@keyframes floatUp {
        0% { opacity: 1; transform: translateY(0) scale(1); }
        100% { opacity: 0; transform: translateY(-80px) scale(1.5); }
    }
    .float-heart {
        position: fixed;
        font-size: 1.5rem;
        pointer-events: none;
        z-index: 300;
        animation: floatUp 1.2s ease-out forwards;
    }
    .float-damage {
        position: fixed;
        font-size: 1.2rem;
        font-weight: 800;
        color: #ef4444;
        pointer-events: none;
        z-index: 300;
        animation: floatUp 1s ease-out forwards;
    }

    /* Shake effect */
    .shake { animation: shakeAnim 0.4s ease; }
    @@keyframes shakeAnim {
        0%, 100% { transform: translateX(0); }
        20% { transform: translateX(-8px); }
        40% { transform: translateX(8px); }
        60% { transform: translateX(-6px); }
        80% { transform: translateX(6px); }
    }

    /* Red flash for trap */
    .red-flash {
        animation: redFlash 0.5s ease;
    }
    @@keyframes redFlash {
        0%, 100% { background-color: transparent; }
        30% { background-color: rgba(239, 68, 68, 0.15); }
    }

    /* Warp effect for skip */
    .warp-effect {
        animation: warpAnim 0.6s ease;
    }
    @@keyframes warpAnim {
        0% { filter: blur(0) hue-rotate(0deg); transform: scale(1); }
        40% { filter: blur(4px) hue-rotate(180deg); transform: scale(0.9); }
        70% { filter: blur(2px) hue-rotate(90deg); transform: scale(1.05); }
        100% { filter: blur(0) hue-rotate(0deg); transform: scale(1); }
    }

    /* Message log color classes */
    .msg-bonus { color: #f59e0b; }
    .msg-correct { color: #4ade80; }
    .msg-wrong { color: #f87171; }
    .msg-heal { color: #22c55e; }
    .msg-trap { color: #ef4444; }
    .msg-skip { color: #a855f7; }

    /* === Responsive === */
    @@media (max-width: 768px) {
        .monopoly-container {
            padding: 6px;
            align-items: flex-start;
        }
        .board-2d {
            grid-template-columns: repeat(7, 50px);
            grid-template-rows: repeat(7, 50px);
            gap: 2px;
        }
        .board-square {
            width: 50px;
            height: 50px;
            border-radius: 6px;
            border-width: 1.5px;
        }
        .board-square .sq-icon { font-size: 0.95rem; }
        .board-square .sq-title { font-size: 0.48rem; }
        .board-square .sq-id { font-size: 0.4rem; }
        .board-square::before { height: 3px; }
        .player-token { font-size: 0.9rem; top: -4px; right: -1px; }
        .center-area { padding: 8px; gap: 6px; }
        .center-title { font-size: 1rem; }
        .center-subtitle { font-size: 0.6rem; }
        .dice-face { font-size: 2rem; width: 46px; height: 46px; border-radius: 10px; }
        .dice-btn { padding: 8px 14px; font-size: 0.8rem; border-radius: 8px; }
        .center-stats { gap: 6px; }
        .stat-badge { padding: 3px 6px; font-size: 0.7rem; gap: 3px; }
        .hp-hearts { font-size: 0.9rem; }
        .coins-value { font-size: 0.85rem; }
        .center-log { max-height: 45px; font-size: 0.6rem; padding: 4px 6px; }
        .dice-area { gap: 8px; }
    }

    @@media (max-width: 420px) {
        .board-2d {
            grid-template-columns: repeat(7, 44px);
            grid-template-rows: repeat(7, 44px);
            gap: 1px;
        }
        .board-square {
            width: 44px;
            height: 44px;
        }
        .board-square .sq-icon { font-size: 0.8rem; }
        .board-square .sq-title { font-size: 0.42rem; }
        .center-title { font-size: 0.85rem; }
        .dice-face { font-size: 1.6rem; width: 38px; height: 38px; }
        .dice-btn { padding: 6px 10px; font-size: 0.7rem; }
        .center-log { display: none; }
    }
</style>

<div class="monopoly-container">
    <div class="board-2d" id="board2d">
        <!-- Row 0 (top): sq18, sq17, sq16, sq15, sq14, sq13, sq12 -->
        <!-- Row 1-5 left: sq19-sq23, right: sq11-sq7 -->
        <!-- Row 6 (bottom): sq0, sq1, sq2, sq3, sq4, sq5, sq6 -->
        <!-- Center area at grid 2/2 -> 7/7 (1-indexed) -->
        <!-- JS will fill squares; center area is static -->

        <!-- Center area placed in the middle -->
        <div class="center-area" id="centerArea">
            <div class="center-title">🎲 程式碼大富翁</div>
            <div class="center-subtitle">擲骰子、答題目、收金幣 — 闖關到終點！</div>
            <div class="dice-area">
                <div class="dice-face" id="diceFace">🎲</div>
                <button class="dice-btn pulsing" id="diceBtn" onclick="rollDice()">🎲 擲骰子</button>
            </div>
            <div class="center-stats">
                <div class="stat-badge">
                    <span style="color:#8b949e;font-size:0.75rem;">HP</span>
                    <span class="hp-hearts" id="hpHearts">❤️❤️❤️</span>
                </div>
                <div class="stat-badge">
                    🪙 <span class="coins-value" id="coinsDisplay">0</span>
                </div>
            </div>
            <div class="center-log" id="messageLog">
                <div class="msg-item">🎮 歡迎！按「擲骰子」開始冒險</div>
            </div>
        </div>
    </div>
</div>

<!-- Question Modal -->
<div class="question-overlay" id="questionOverlay">
    <div class="question-card">
        <h3 id="questionTitle"></h3>
        <div class="question-text" id="questionText"></div>
        <div class="timer-bar-wrap">
            <div class="timer-bar" id="timerBar"></div>
        </div>
        <div class="timer-text">⏱️ 剩餘 <span id="timerSeconds">10</span> 秒</div>
        <div class="options-list" id="optionsList"></div>
        <div class="coins-reward" id="coinsReward"></div>
    </div>
</div>

<!-- Event Popup -->
<div class="event-popup" id="eventPopup">
    <div class="event-card">
        <div class="event-icon" id="eventIcon"></div>
        <div class="event-title" id="eventTitle"></div>
        <div class="event-desc" id="eventDesc"></div>
        <button class="event-ok-btn" id="eventOkBtn" onclick="closeEvent()">繼續冒險</button>
    </div>
</div>

<!-- Game Over Overlay -->
<div class="gameover-overlay" id="gameoverOverlay">
    <div class="gameover-card">
        <div class="result-emoji" id="resultEmoji"></div>
        <h2 id="resultTitle"></h2>
        <div class="stat-grid">
            <div class="stat-item">
                <div class="stat-value" id="statCoins">0</div>
                <div class="stat-label">🪙 總金幣</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="statSquares">0</div>
                <div class="stat-label">🗺️ 走過格數</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="statCorrect">0</div>
                <div class="stat-label">✅ 答對題數</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="statTotal">0</div>
                <div class="stat-label">📝 總題數</div>
            </div>
        </div>
        <div class="gameover-btns">
            <button class="btn-secondary" onclick="location.href='/Monopoly'">🔄 再玩一次</button>
            <button class="btn-primary" onclick="location.href='/'">🏠 回首頁</button>
        </div>
    </div>
</div>

<script>
(function() {
    // === State ===
    let board = [];
    let playerPos = 0;
    let hp = 3;
    let maxHp = 3;
    let coins = 0;
    let isRolling = false;
    let gameOver = false;
    let questionsAnswered = 0;
    let questionsCorrect = 0;
    let squaresVisited = 0;
    let questionTimer = null;
    let questionTimeLeft = 10;
    let pendingEventCallback = null;

    // === DOM ===
    const board2d = document.getElementById('board2d');
    const centerArea = document.getElementById('centerArea');
    const hpHearts = document.getElementById('hpHearts');
    const coinsDisplay = document.getElementById('coinsDisplay');
    const diceFace = document.getElementById('diceFace');
    const diceBtn = document.getElementById('diceBtn');
    const messageLog = document.getElementById('messageLog');
    const questionOverlay = document.getElementById('questionOverlay');
    const eventPopup = document.getElementById('eventPopup');
    const gameoverOverlay = document.getElementById('gameoverOverlay');

    // === Board position mapping ===
    // The 2D board layout (7x7 grid):
    //   Row 0 (top):    sq18  sq17  sq16  sq15  sq14  sq13  sq12
    //   Row 1: sq19  [center .........................]  sq11
    //   Row 2: sq20  [center .........................]  sq10
    //   Row 3: sq21  [center .........................]  sq9
    //   Row 4: sq22  [center .........................]  sq8
    //   Row 5: sq23  [center .........................]  sq7
    //   Row 6 (bot):  sq0   sq1   sq2   sq3   sq4   sq5   sq6

    // Map board index -> {row, col} in the 7x7 grid
    function getBoardPositions(totalSquares) {
        const positions = [];
        // We have 24 edge positions (7+5+7+5 = 24) around a 7x7 grid
        // Bottom row (row 6): cols 0-6 = squares 0-6
        // Right col (col 6): rows 5-1 = squares 7-11
        // Top row (row 0): cols 6-0 = squares 12-18
        // Left col (col 0): rows 1-5 = squares 19-23
        // Then if more squares, they wrap

        const edgeSlots = [];
        // Bottom: row=6, col=0..6
        for (let c = 0; c <= 6; c++) edgeSlots.push({ row: 6, col: c });
        // Right: row=5..1, col=6
        for (let r = 5; r >= 1; r--) edgeSlots.push({ row: r, col: 6 });
        // Top: row=0, col=6..0
        for (let c = 6; c >= 0; c--) edgeSlots.push({ row: 0, col: c });
        // Left: row=1..5, col=0
        for (let r = 1; r <= 5; r++) edgeSlots.push({ row: r, col: 0 });

        // Total edge slots = 7+5+7+5 = 24
        for (let i = 0; i < totalSquares && i < edgeSlots.length; i++) {
            positions.push(edgeSlots[i]);
        }
        return positions;
    }

    // Icon map for square types
    function getSquareIcon(sq) {
        switch (sq.type) {
            case 'start': return '🏁';
            case 'finish': return '🏆';
            case 'question': return '❓';
            case 'bonus': return '💰';
            case 'trap': return '💀';
            case 'heal': return '💚';
            case 'skip': return '⏩';
            default: return '📍';
        }
    }

    // Short title (max ~8 chars for display)
    function shortTitle(title) {
        if (!title) return '';
        if (title.length <= 10) return title;
        return title.substring(0, 9) + '…';
    }

    // === Init ===
    fetch('/Monopoly/GetBoard')
        .then(r => r.json())
        .then(data => {
            board = data;
            renderBoard();
        });

    // === Board Rendering ===
    function renderBoard() {
        // Clear all square elements (keep center area)
        const existingSquares = board2d.querySelectorAll('.board-square');
        existingSquares.forEach(el => el.remove());

        const positions = getBoardPositions(board.length);

        // We need to place each square at the correct grid position
        // CSS grid is 7 cols x 7 rows
        // Center area occupies cols 2-6, rows 2-6 (1-indexed CSS grid: col 2/7, row 2/7)
        positions.forEach((pos, idx) => {
            if (idx >= board.length) return;
            const sq = board[idx];
            const el = document.createElement('div');
            el.className = 'board-square sq-' + sq.type;
            el.id = 'sq-' + sq.id;
            // Place in grid (CSS grid is 1-indexed)
            el.style.gridColumn = (pos.col + 1).toString();
            el.style.gridRow = (pos.row + 1).toString();

            el.innerHTML = `
                <div class="sq-icon">${getSquareIcon(sq)}</div>
                <div class="sq-title">${shortTitle(sq.title)}</div>
                <div class="sq-id">#${sq.id}</div>
            `;

            if (idx === playerPos) {
                el.classList.add('sq-current');
                el.innerHTML += '<div class="player-token">🧑‍💻</div>';
            }
            board2d.appendChild(el);
        });
    }

    function updateBoard() {
        // Remove old current/visited states and tokens
        document.querySelectorAll('.board-square').forEach(el => {
            el.classList.remove('sq-current');
            const token = el.querySelector('.player-token');
            if (token) token.remove();
        });

        // Mark visited squares
        for (let i = 0; i < playerPos; i++) {
            const el = document.getElementById('sq-' + i);
            if (el) el.classList.add('sq-visited');
        }

        // Set current
        const cur = document.getElementById('sq-' + playerPos);
        if (cur) {
            cur.classList.add('sq-current');
            cur.classList.remove('sq-visited');
            cur.innerHTML += '<div class="player-token">🧑‍💻</div>';
        }
    }

    // === HP ===
    function updateHp() {
        let html = '';
        for (let i = 0; i < maxHp; i++) {
            if (i < hp) html += '❤️';
            else html += '<span class="heart-lost">🖤</span>';
        }
        hpHearts.innerHTML = html;
    }

    // === Coins ===
    function addCoins(amount) {
        coins += amount;
        coinsDisplay.textContent = coins;
        coinsDisplay.style.transform = 'scale(1.4)';
        coinsDisplay.style.color = '#fbbf24';
        setTimeout(() => {
            coinsDisplay.style.transform = 'scale(1)';
            coinsDisplay.style.color = '#f59e0b';
        }, 300);
    }

    function spawnFloatingCoin(x, y) {
        const el = document.createElement('div');
        el.className = 'float-coin';
        el.textContent = '🪙';
        el.style.left = x + 'px';
        el.style.top = y + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1200);
    }

    function spawnFloatingHeart(x, y) {
        const el = document.createElement('div');
        el.className = 'float-heart';
        el.textContent = '❤️';
        el.style.left = x + 'px';
        el.style.top = y + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1200);
    }

    function spawnFloatingDamage(x, y, text) {
        const el = document.createElement('div');
        el.className = 'float-damage';
        el.textContent = text;
        el.style.left = x + 'px';
        el.style.top = y + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1000);
    }

    // === Message Log ===
    function logMsg(text, cls) {
        const el = document.createElement('div');
        el.className = 'msg-item' + (cls ? ' msg-' + cls : '');
        el.textContent = text;
        messageLog.appendChild(el);
        messageLog.scrollTop = messageLog.scrollHeight;
    }

    // === Dice ===
    window.rollDice = function() {
        if (isRolling || gameOver) return;
        isRolling = true;
        diceBtn.disabled = true;
        diceBtn.classList.remove('pulsing');

        const diceFaces = ['\u2680','\u2681','\u2682','\u2683','\u2684','\u2685'];
        let rollCount = 0;
        const rollInterval = setInterval(() => {
            diceFace.textContent = diceFaces[Math.floor(Math.random() * 6)];
            diceFace.classList.add('dice-rolling');
            rollCount++;
            if (rollCount > 15) {
                clearInterval(rollInterval);
                const value = Math.floor(Math.random() * 6) + 1;
                diceFace.textContent = diceFaces[value - 1];
                diceFace.classList.remove('dice-rolling');
                logMsg('🎲 骰子擲出 ' + value + '！', '');
                movePlayer(value);
            }
        }, 80);
    };

    function movePlayer(steps) {
        let target = Math.min(playerPos + steps, board.length - 1);
        squaresVisited += (target - playerPos);

        let current = playerPos;
        const stepInterval = setInterval(() => {
            current++;
            if (current > target) {
                clearInterval(stepInterval);
                playerPos = target;
                updateBoard();
                handleSquare();
                return;
            }
            playerPos = current;
            updateBoard();
        }, 300);
    }

    // === Square Handler ===
    function handleSquare() {
        if (playerPos >= board.length) {
            endGame(true);
            return;
        }
        const sq = board[playerPos];

        switch (sq.type) {
            case 'start':
                logMsg('🏁 冒險開始！', '');
                finishTurn();
                break;
            case 'question':
                showQuestion(sq);
                break;
            case 'bonus':
                showEvent('💰', sq.title, sq.description, () => {
                    addCoins(sq.coins);
                    spawnCoinBurst();
                    logMsg('💰 獲得 ' + sq.coins + ' 金幣！', 'bonus');
                    finishTurn();
                });
                break;
            case 'trap':
                if (sq.skipAmount && sq.skipAmount < 0) {
                    showEvent('🕳️', sq.title, sq.description, () => {
                        logMsg('🕳️ ' + sq.description, 'trap');
                        triggerTrapEffect();
                        playerPos = Math.max(0, playerPos + sq.skipAmount);
                        updateBoard();
                        finishTurn();
                    });
                } else {
                    showEvent('💀', sq.title, sq.description, () => {
                        hp += sq.hpChange;
                        updateHp();
                        shakeScreen();
                        triggerTrapEffect();
                        spawnFloatingDamage(window.innerWidth / 2, window.innerHeight / 2, '-1 HP');
                        logMsg('💀 失去 1 條命！', 'trap');
                        if (hp <= 0) {
                            endGame(false);
                        } else {
                            finishTurn();
                        }
                    });
                }
                break;
            case 'heal':
                showEvent('❤️', sq.title, sq.description, () => {
                    if (hp < maxHp) {
                        hp += sq.hpChange;
                        if (hp > maxHp) hp = maxHp;
                        updateHp();
                        spawnHealBurst();
                    }
                    logMsg('❤️ ' + sq.description, 'heal');
                    finishTurn();
                });
                break;
            case 'skip':
                showEvent('⏩', sq.title, sq.description, () => {
                    logMsg('⏩ ' + sq.description, 'skip');
                    triggerWarpEffect();
                    playerPos = Math.min(board.length - 1, Math.max(0, playerPos + sq.skipAmount));
                    squaresVisited += Math.abs(sq.skipAmount);
                    updateBoard();
                    if (playerPos >= board.length - 1) {
                        endGame(true);
                    } else {
                        finishTurn();
                    }
                });
                break;
            case 'finish':
                endGame(true);
                break;
            default:
                finishTurn();
        }
    }

    function finishTurn() {
        isRolling = false;
        diceBtn.disabled = false;
        diceBtn.classList.add('pulsing');
    }

    // === Question Modal ===
    function showQuestion(sq) {
        document.getElementById('questionTitle').textContent = sq.title;
        document.getElementById('questionText').textContent = sq.question;
        document.getElementById('coinsReward').textContent = '答對可獲得 ' + sq.coins + ' 🪙';

        const optList = document.getElementById('optionsList');
        optList.innerHTML = '';
        sq.options.forEach((opt, i) => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.textContent = String.fromCharCode(65 + i) + '. ' + opt;
            btn.onclick = () => selectAnswer(i, sq);
            optList.appendChild(btn);
        });

        questionTimeLeft = 10;
        document.getElementById('timerSeconds').textContent = '10';
        document.getElementById('timerBar').style.width = '100%';

        questionOverlay.classList.add('active');
        questionsAnswered++;

        questionTimer = setInterval(() => {
            questionTimeLeft -= 0.1;
            if (questionTimeLeft <= 0) {
                questionTimeLeft = 0;
                clearInterval(questionTimer);
                timeoutAnswer(sq);
            }
            document.getElementById('timerBar').style.width = (questionTimeLeft / 10 * 100) + '%';
            document.getElementById('timerSeconds').textContent = Math.ceil(questionTimeLeft);
        }, 100);
    }

    function selectAnswer(idx, sq) {
        clearInterval(questionTimer);
        const buttons = document.querySelectorAll('.option-btn');
        buttons.forEach(b => b.disabled = true);

        if (idx === sq.answer) {
            buttons[idx].classList.add('correct');
            questionsCorrect++;
            addCoins(sq.coins);
            spawnCoinBurst();
            logMsg('✅ 答對了！+' + sq.coins + ' 金幣', 'correct');
            setTimeout(() => {
                questionOverlay.classList.remove('active');
                finishTurn();
            }, 1000);
        } else {
            buttons[idx].classList.add('wrong');
            buttons[sq.answer].classList.add('correct');
            hp--;
            updateHp();
            shakeScreen();
            spawnFloatingDamage(window.innerWidth / 2, window.innerHeight / 2, '-1 HP');
            logMsg('❌ 答錯了！正確答案是 ' + String.fromCharCode(65 + sq.answer), 'wrong');
            setTimeout(() => {
                questionOverlay.classList.remove('active');
                if (hp <= 0) {
                    endGame(false);
                } else {
                    finishTurn();
                }
            }, 1500);
        }
    }

    function timeoutAnswer(sq) {
        const buttons = document.querySelectorAll('.option-btn');
        buttons.forEach(b => b.disabled = true);
        buttons[sq.answer].classList.add('correct');
        hp--;
        updateHp();
        shakeScreen();
        spawnFloatingDamage(window.innerWidth / 2, window.innerHeight / 2, '⏰ 時間到！');
        logMsg('⏰ 時間到！失去 1 條命', 'wrong');
        setTimeout(() => {
            questionOverlay.classList.remove('active');
            if (hp <= 0) {
                endGame(false);
            } else {
                finishTurn();
            }
        }, 1500);
    }

    // === Event Popup ===
    function showEvent(icon, title, desc, callback) {
        document.getElementById('eventIcon').textContent = icon;
        document.getElementById('eventTitle').textContent = title;
        document.getElementById('eventDesc').textContent = desc;
        pendingEventCallback = callback;
        eventPopup.classList.add('active');
    }

    window.closeEvent = function() {
        eventPopup.classList.remove('active');
        if (pendingEventCallback) {
            const cb = pendingEventCallback;
            pendingEventCallback = null;
            cb();
        }
    };

    // === Effects ===
    function shakeScreen() {
        const container = document.querySelector('.monopoly-container');
        container.classList.remove('shake');
        void container.offsetWidth;
        container.classList.add('shake');
    }

    function triggerTrapEffect() {
        const container = document.querySelector('.monopoly-container');
        container.classList.remove('red-flash');
        void container.offsetWidth;
        container.classList.add('red-flash');
    }

    function triggerWarpEffect() {
        const board = document.getElementById('board2d');
        board.classList.remove('warp-effect');
        void board.offsetWidth;
        board.classList.add('warp-effect');
    }

    function spawnCoinBurst() {
        for (let i = 0; i < 6; i++) {
            setTimeout(() => {
                spawnFloatingCoin(
                    window.innerWidth / 2 + (Math.random() - 0.5) * 200,
                    window.innerHeight / 2 + (Math.random() - 0.5) * 100
                );
            }, i * 100);
        }
    }

    function spawnHealBurst() {
        for (let i = 0; i < 4; i++) {
            setTimeout(() => {
                spawnFloatingHeart(
                    window.innerWidth / 2 + (Math.random() - 0.5) * 150,
                    window.innerHeight / 2 + (Math.random() - 0.5) * 80
                );
            }, i * 150);
        }
    }

    // === Game Over ===
    function endGame(won) {
        gameOver = true;
        isRolling = true;
        diceBtn.disabled = true;
        diceBtn.classList.remove('pulsing');

        if (won) {
            document.getElementById('resultEmoji').textContent = '🏆🎉🎊';
            document.getElementById('resultTitle').textContent = '恭喜通關！';
            logMsg('🏆 恭喜抵達終點！', 'correct');
        } else {
            document.getElementById('resultEmoji').textContent = '💀😵';
            document.getElementById('resultTitle').textContent = '遊戲結束';
            logMsg('💀 生命歸零，遊戲結束...', 'trap');
        }

        document.getElementById('statCoins').textContent = coins;
        document.getElementById('statSquares').textContent = squaresVisited;
        document.getElementById('statCorrect').textContent = questionsCorrect;
        document.getElementById('statTotal').textContent = questionsAnswered;

        setTimeout(() => {
            gameoverOverlay.classList.add('active');
        }, 500);
    }
})();
</script>
