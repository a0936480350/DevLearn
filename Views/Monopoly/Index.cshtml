@{
    ViewData["Title"] = "程式碼大富翁";
}

<style>
    .monopoly-phaser-wrap {
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0;
    }
    .monopoly-phaser-container {
        width: 100%;
        aspect-ratio: 3 / 2;
        max-height: calc(100vh - 80px);
        background: #0d1117;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        z-index: 10;
    }
    /* Hide floating buttons that overlap the game */
    .gesture-btn, .voice-btn, .line-float-btn,
    [style*="position: fixed"][style*="bottom"] {
        display: none !important;
    }
</style>

<div class="monopoly-phaser-wrap">
    <div class="monopoly-phaser-container" id="game-container"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/phaser@3.80.1/dist/phaser.min.js"></script>
<script type="module" src="/js/games/monopoly/main.js?v=20260411j"></script>
